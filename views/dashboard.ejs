<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<!-- 1. STAT CARDS -->
<div class="stat-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 24px;">
    <!-- Card 1 -->
    <div class="card" style="padding: 24px; display: flex; align-items: center; gap: 16px; border-radius: 16px; background: #fff; box-shadow: 0 4px 20px rgba(0,0,0,.02); border: 1px solid rgba(0,0,0,.04);">
        <div style="width: 54px; height: 54px; border-radius: 12px; background: #f72c91; color: #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
        </div>
        <div>
            <div style="color: #666; font-size: 13px; font-weight: 500; margin-bottom: 4px;">Total Orders</div>
            <div style="font-size: 26px; font-weight: 800; color: #111; line-height: 1;"><%= stats.totalOrders || 0 %></div>
            <div style="font-size: 11px; color: #888; margin-top: 6px;">Updated just now</div>
        </div>
    </div>
    <!-- Card 2 -->
    <div class="card" style="padding: 24px; display: flex; align-items: center; gap: 16px; border-radius: 16px; background: #fff; box-shadow: 0 4px 20px rgba(0,0,0,.02); border: 1px solid rgba(0,0,0,.04);">
        <div style="width: 54px; height: 54px; border-radius: 12px; background: #f72c91; color: #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        </div>
        <div>
            <div style="color: #666; font-size: 13px; font-weight: 500; margin-bottom: 4px;">Pending Orders</div>
            <div style="font-size: 26px; font-weight: 800; color: #111; line-height: 1;"><%= stats.pendingOrders || 0 %></div>
            <div style="font-size: 11px; color: #888; margin-top: 6px;">Real-time status</div>
        </div>
    </div>
    <!-- Card 3 -->
    <div class="card" style="padding: 24px; display: flex; align-items: center; gap: 16px; border-radius: 16px; background: #fff; box-shadow: 0 4px 20px rgba(0,0,0,.02); border: 1px solid rgba(0,0,0,.04);">
        <div style="width: 54px; height: 54px; border-radius: 12px; background: #f72c91; color: #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div>
            <div style="color: #666; font-size: 13px; font-weight: 500; margin-bottom: 4px;">Total Customers</div>
            <div style="font-size: 26px; font-weight: 800; color: #111; line-height: 1;"><%= stats.totalCustomers || 0 %></div>
            <div style="font-size: 11px; color: #888; margin-top: 6px;">Active user base</div>
        </div>
    </div>
    <!-- Card 4 -->
    <div class="card" style="padding: 24px; display: flex; align-items: center; gap: 16px; border-radius: 16px; background: #fff; box-shadow: 0 4px 20px rgba(0,0,0,.02); border: 1px solid rgba(0,0,0,.04);">
        <div style="width: 54px; height: 54px; border-radius: 12px; background: #f72c91; color: #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 22px; font-weight: 800;">
            $
        </div>
        <div>
            <div style="color: #666; font-size: 13px; font-weight: 500; margin-bottom: 4px;">Return / Refund Requests</div>
            <div style="font-size: 26px; font-weight: 800; color: #111; line-height: 1;"><%= stats.refunds || 0 %></div>
            <div style="font-size: 11px; color: #888; margin-top: 6px;">Total value</div>
        </div>
    </div>
</div>

<!-- 2. MIDDLE LAYOUT GRID -->
<div style="display: grid; grid-template-columns: 1fr 340px; gap: 24px; margin-bottom: 32px;">
    
    <!-- LEFT SIDE -->
    <div style="display: flex; flex-direction: column; gap: 24px;">
        
        <!-- BANNER CARD -->
        <div style="background: #fff; border-radius: 16px; padding: 32px; box-shadow: 0 4px 20px rgba(0,0,0,.02); border: 1px solid rgba(0,0,0,.04); display: flex; justify-content: space-between; align-items: center;">
            <div style="max-width: 320px;">
                <div style="color: #666; font-size: 13px; font-weight: 600; margin-bottom: 8px;">Built for store managers</div>
                <h2 style="font-size: 22px; font-weight: 800; color: #111; margin-bottom: 12px;">Order Management</h2>
                <p style="color: #777; font-size: 14px; line-height: 1.6; margin-bottom: 20px;">
                    Track every order from checkout to delivery. Manage statuses, payments, and shipment updates all in one place.
                </p>
                <a href="/orders" style="color: #f72c91; font-weight: 600; font-size: 14px; display: inline-flex; align-items: center; gap: 4px;">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
            </div>
            <div style="width: 160px; height: 120px; border-radius: 16px; background: linear-gradient(135deg, #f72c91, #b721ff); display: flex; align-items: center; justify-content: center; color: #fff; box-shadow: 0 8px 25px rgba(247,44,145,0.3);">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 3.86-8.86c.86-1.14 2.14-2.14 3.14-2.14 1 0 1.5 1.5 1.5 3.5 0 2.5-1.5 5.5-2.5 6.5A22 22 0 0 1 12 15Z"/><path d="m15.5 12 3 3a22 22 0 0 1-5.14 5.86c-1.14.86-2.14 2.14-3.14 2.14-1 0-1.5-1.5-1.5-3.5 0-2.5 1.5-5.5 2.5-6.5A22 22 0 0 1 15.5 12Z"/><path d="M9 18v3"/><path d="M14 12H9"/></svg>
            </div>
        </div>

        <!-- RECENT ACTIVITY (Simple Text) -->
        <div style="background: #fff; border-radius: 16px; padding: 28px; box-shadow: 0 4px 20px rgba(0,0,0,.02); border: 1px solid rgba(0,0,0,.04);">
            <h3 style="font-size: 16px; font-weight: 700; color: #111; margin-bottom: 24px;">Recent Activity</h3>
            <% if(recentOrders && recentOrders.length) { %>
                <% recentOrders.slice(0, 5).forEach(o => { 
                    let title = `New order #${o.id + 1832000}`;
                    if(o.status === 'Refunded') title = `Return requested #${o.id + 1832000}`;
                    if(o.status === 'Paid' || o.status === 'Processed') title = `Payment received #${o.id + 1832000}`;
                    
                    const d = new Date(o.date);
                    const timeStr = !isNaN(d) ? d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) + ' ' + d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) : o.date;
                %>
                <div style="display: flex; justify-content: space-between; padding: 16px 0; border-bottom: 1px solid #f0f0f0;">
                    <span style="font-size: 14px; font-weight: 600; color: #333;"><%= title %></span>
                    <span style="font-size: 12px; color: #888; font-weight: 500;"><%= timeStr %></span>
                </div>
                <% }) %>
            <% } else { %>
                <div class="empty" style="padding: 20px !important;">No activity yet.</div>
            <% } %>
        </div>

    </div>

    <!-- RIGHT SIDE: Orders Overview (Timeline with badges) -->
    <div style="background: #fff; border-radius: 16px; padding: 28px; box-shadow: 0 4px 20px rgba(0,0,0,.02); border: 1px solid rgba(0,0,0,.04);">
        <h3 style="font-size: 16px; font-weight: 700; color: #111; margin-bottom: 24px;">Orders Overview</h3>
        
        <% if(recentOrders && recentOrders.length) { %>
            <% recentOrders.slice(0, 6).forEach(o => { 
                let badgeClass = 'badge-solid-gray';
                if(o.status === 'Delivered') badgeClass = 'badge-solid-green';
                if(o.status === 'Refunded') badgeClass = 'badge-solid-gray';
                if(o.status === 'Paid' || o.status === 'Processed') badgeClass = 'badge-solid-purple';
                if(o.status === 'Processing' || o.status === 'Pending') badgeClass = 'badge-solid-orange';
                if(o.status === 'Shipped') badgeClass = 'badge-solid-blue';

                const d = new Date(o.date);
                const timeStr = !isNaN(d) ? d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) + ' ' + d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) : o.date;
                
                let title = `New order #${o.id + 1832000}`;
                if(o.status === 'Refunded') title = `Return requested #${o.id + 1832000}`;
                if(o.status === 'Paid' || o.status === 'Processed') title = `Payment received #${o.id + 1832000}`;
            %>
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 14px; border: 1px solid #f0f0f0; border-radius: 12px; margin-bottom: 12px;">
                <div>
                    <div style="font-size: 13.5px; font-weight: 600; color: #333; margin-bottom: 4px;"><%= title %></div>
                    <div style="font-size: 11px; color: #888; font-weight: 500;"><%= timeStr %></div>
                </div>
                <span class="activity-badge <%= badgeClass %>"><%= o.status %></span>
            </div>
            <% }) %>
        <% } else { %>
            <div class="empty" style="padding: 20px !important;">No orders yet.</div>
        <% } %>
    </div>

</div>

<!-- 3. DETAILED ORDERS TABLE -->
<div class="card" style="padding: 0; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,.02); border: 1px solid rgba(0,0,0,.04);">
    <div style="overflow-x: auto;">
      <table class="tbl">
        <thead>
          <tr style="background: #fff;">
            <th>Order ID</th>
            <th>Customer Name</th>
            <th>Status</th>
            <th>Payment Method</th>
            <th>Amount</th>
            <th>Order Date</th>
            <th>Quick Action</th>
          </tr>
        </thead>
        <tbody style="background: #fff;">
          <% if(recentOrders && recentOrders.length) { %>
            <% recentOrders.forEach(o => { 
              const amount = o.product_price ? `$${(o.product_price * (o.qty || 1)).toFixed(2)}` : '$0.00';
              const dateObj = new Date(o.date);
              const dateStr = !isNaN(dateObj) ? dateObj.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : o.date;
            %>
            <tr>
              <td style="color: #666;">#<%= o.id + 10000 %></td>
              <td style="font-weight: 600;"><%= o.user_name || 'Guest User' %></td>
              <td><%= o.status %></td>
              <td>Credit Card</td>
              <td class="price"><%= amount %></td>
              <td><%= dateStr %></td>
              <td class="action-dots">⋮</td>
            </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="7" class="empty">No recent orders found.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
</div>

<%- include('partials/footer') %>
