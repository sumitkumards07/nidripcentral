<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>NI DRIP CENTRAL - Welcome</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
          tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                colors: {
                  "tertiary-container": "#261906",
                  "on-secondary-container": "#fffbff",
                  "secondary": "#4b41e1",
                  "on-primary-fixed": "#141b2b",
                  "on-error-container": "#93000a",
                  "on-secondary": "#ffffff",
                  "surface-variant": "#e1e3e4",
                  "surface-tint": "#575e70",
                  "outline": "#76777d",
                  "on-surface": "#191c1d",
                  "error": "#ba1a1a",
                  "on-primary-fixed-variant": "#404758",
                  "surface-dim": "#d9dadb",
                  "surface": "#f8f9fa",
                  "surface-container-highest": "#e1e3e4",
                  "outline-variant": "#c6c6cd",
                  "inverse-primary": "#c0c6db",
                  "inverse-on-surface": "#f0f1f2",
                  "on-background": "#191c1d",
                  "background": "#f8f9fa",
                  "surface-bright": "#f8f9fa",
                  "primary-container": "#141b2b",
                  "inverse-surface": "#2e3132",
                  "on-primary": "#ffffff",
                  "tertiary": "#000000",
                  "error-container": "#ffdad6",
                  "tertiary-fixed-dim": "#dcc2a4",
                  "secondary-container": "#645efb",
                  "on-surface-variant": "#45464c",
                  "on-error": "#ffffff",
                  "on-secondary-fixed": "#0f0069",
                  "tertiary-fixed": "#f9debf",
                  "on-tertiary-fixed": "#261906",
                  "surface-container": "#edeeef",
                  "surface-container-low": "#f3f4f5",
                  "on-tertiary-fixed-variant": "#55442d",
                  "primary-fixed-dim": "#c0c6db",
                  "primary": "#000000",
                  "on-primary-container": "#7d8497",
                  "secondary-fixed": "#e2dfff",
                  "on-tertiary": "#ffffff",
                  "on-tertiary-container": "#968065",
                  "on-secondary-fixed-variant": "#3323cc",
                  "secondary-fixed-dim": "#c3c0ff",
                  "primary-fixed": "#dce2f7",
                  "surface-container-high": "#e7e8e9",
                  "surface-container-lowest": "#ffffff"
                },
                fontFamily: {
                  "headline": ["Plus Jakarta Sans"],
                  "body": ["Inter"],
                  "label": ["Inter"]
                },
                borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
              },
            },
          }
        </script>
    <style>
            .material-symbols-outlined {
                font-variation-settings: 'FILL' 0, 'wght' 200, 'GRAD' 0, 'opsz' 24;
                font-size: 20px;
            }
            body {
                font-family: 'Inter', sans-serif;
            }
            h1, h2, h3 {
                font-family: 'Plus Jakarta Sans', sans-serif;
            }
        </style>
    <style>
        body {
          min-height: max(884px, 100dvh);
        }
      </style>
</head>
<body class="bg-surface text-on-surface min-h-screen flex flex-col items-center justify-center p-6 sm:p-8">
    <main class="w-full max-w-md flex flex-col items-center space-y-12">
        <div class="flex flex-col items-center text-center space-y-4">
            <div class="w-16 h-16 bg-primary flex items-center justify-center rounded-xl shadow-lg mb-2">
                <span class="material-symbols-outlined text-white text-4xl" data-icon="water_drop">water_drop</span>
            </div>
            <h1 class="text-3xl font-extrabold tracking-tighter text-primary">NI DRIP CENTRAL</h1>
            <p class="text-on-surface-variant font-body text-sm tracking-wide">CURATING THE FUTURE OF DRIP</p>
        </div>
        <div class="w-full flex flex-col space-y-4">
            <button onclick="window.location.href='/login'" class="w-full h-14 bg-primary text-on-primary font-headline font-bold rounded-xl active:scale-[0.98] transition-all flex items-center justify-center shadow-[0_4px_20px_rgba(0,0,0,0.08)]">
                Log In
            </button>
            <button onclick="window.location.href='/signup'" class="w-full h-14 bg-surface-container-lowest text-primary font-headline font-bold rounded-xl border border-outline-variant/30 active:scale-[0.98] transition-all flex items-center justify-center">
                Sign Up
            </button>
        </div>
        <div class="w-full flex items-center space-x-4">
            <div class="h-[1px] flex-1 bg-outline-variant opacity-20"></div>
            <span class="text-on-surface-variant font-label text-xs uppercase tracking-widest">Or</span>
            <div class="h-[1px] flex-1 bg-outline-variant opacity-20"></div>
        </div>
        <div class="w-full flex flex-col space-y-4">
            <button class="w-full h-14 bg-surface-container-lowest text-on-surface font-body font-medium rounded-full border border-outline-variant/30 active:scale-[0.98] transition-all flex items-center px-8 relative">
                <span class="material-symbols-outlined absolute left-6" data-icon="google">google</span>
                <span class="w-full text-center">Continue with Google</span>
            </button>
            <button class="w-full h-14 bg-surface-container-lowest text-on-surface font-body font-medium rounded-full border border-outline-variant/30 active:scale-[0.98] transition-all flex items-center px-8 relative">
                <span class="material-symbols-outlined absolute left-6" data-icon="facebook">social_leaderboard</span>
                <span class="w-full text-center">Continue with Facebook</span>
            </button>
        </div>
        <div class="pt-8 text-center">
            <p class="text-on-surface-variant text-xs leading-relaxed max-w-[280px] font-body">
                By continuing, you agree to our <a class="text-secondary font-semibold" href="#">Terms of Service</a> and <a class="text-secondary font-semibold" href="#">Privacy Policy</a>.
            </p>
        </div>
    </main>
    <div class="fixed top-[-10%] left-[-10%] w-64 h-64 bg-secondary/5 rounded-full blur-3xl pointer-events-none -z-10"></div>
    <div class="fixed bottom-[-5%] right-[-5%] w-80 h-80 bg-primary/5 rounded-full blur-3xl pointer-events-none -z-10"></div>
</body>
</html>

