<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NI DRIP - Welcome</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body>
  <div class="mobile-frame">
    <div class="auth-bg">



      <div class="welcome-logo"></div>

      <div class="auth-buttons-container">
        <!-- Log In / Sign Up Group -->
        <div class="auth-btn-group">
          <button class="auth-btn-primary" onclick="window.location.href='/login'">Log In</button>
          <button class="auth-btn-outline" onclick="window.location.href='/signup'">Sign Up</button>
        </div>

        <!-- Divider -->
        <div class="divider-auth">
          <div class="divider-line"></div>
          <span class="divider-text">Or</span>
          <div class="divider-line"></div>
        </div>

        <!-- Social Buttons Group -->
        <div class="auth-btn-group">
          <button class="btn-social-auth">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="20">
            Continue with Google
          </button>
          <button class="btn-social-auth">
            <img src="https://upload.wikimedia.org/wikipedia/commons/b/b8/2021_Facebook_icon.svg" width="20">
            Continue with Facebook
          </button>
        </div>
      </div>

      <!-- Home Indicator -->
      <div style="width: 134px; height: 5px; background: #000000; border-radius: 100px; position: absolute; bottom: 8px; left: calc(50% - 67px); opacity: 0.1;"></div>
    </div>
  </div>
</body>
</html>
