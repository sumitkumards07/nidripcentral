<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            height: 100vh;
            overflow: hidden;
        }

        /* ====== MAIN WRAPPER ====== */
        .login-wrapper {
            display: flex;
            height: 100vh;
        }

        /* ====== LEFT SIDE ====== */
        .left-side {
            width: 50%;
            background: linear-gradient(180deg, #ff2b8a 0%, #ff3aa6 40%, #6ee28e 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        /* LOGIN CARD + LOGO */
        .login-container {
            position: relative;
            z-index: 10;
            text-align: center;
        }

        .logo-container {
            margin-bottom: 20px;
        }

        .logo-container img {
            max-height: 80px;
        }

        /* Card */
        .login-card {
            width: 380px;
            background: #ffffff15;
            backdrop-filter: blur(15px);
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
            color: #fff;
            margin: auto;
        }

        /* Form Title */
        .login-card h2 {
            text-align: center;
            margin-bottom: 25px;
            font-weight: 600;
        }

        /* Input Groups */
        .input-group {
            margin-bottom: 18px;
            position: relative;
        }

        .input-group input {
            width: 100%;
            padding: 12px 12px 12px 40px;
            /* padding-left for left icon */
            border-radius: 6px;
            border: none;
            outline: none;
            font-size: 14px;
            background: rgba(255, 255, 255, 0.2);
            color: #fff;
        }

        .input-group input::placeholder {
            color: #fff;
            opacity: 0.8;
        }

        .input-group input:focus {
            box-shadow: 0 0 12px rgba(255, 255, 255, 0.8);
            background: rgba(255, 255, 255, 0.3);
        }

        /* Icons inside input - LEFT side */
        .input-group .fas {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #ff2b8a;
            font-size: 16px;
        }

        /* Login Button */
        .login-btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            cursor: pointer;
            background: #ff2b8a;
            color: #fff;
            transition: 0.3s;
        }

        .login-btn:hover {
            transform: translateY(-2px);
            opacity: 0.9;
        }

        /* Remember Me style */
        .remember {
            margin-bottom: 15px;
            font-size: 13px;
            display: flex;
            align-items: center;
            color: #fff;
        }

        .remember input[type="checkbox"] {
            margin-right: 8px;
        }

        /* ====== RIGHT SIDE ====== */
        .right-side {
            width: 50%;
            background: #ffffff;
            position: relative;
            overflow: hidden;
        }

        /* Floating Balls */
        .ball {
            position: absolute;
            border-radius: 50%;
            opacity: 0.85;
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
            animation: float linear infinite;
        }

        @keyframes float {
            0% {
                transform: translate(0, 0);
            }

            50% {
                transform: translate(var(--x), var(--y));
            }

            100% {
                transform: translate(0, 0);
            }
        }

        /* Responsive */
        @media(max-width:900px) {
            .login-wrapper {
                flex-direction: column;
            }

            .left-side,
            .right-side {
                width: 100%;
                height: 50vh;
            }
        }
    </style>
</head>

<body>

    <div class="login-wrapper">

        <!-- LEFT SIDE -->
        <div class="left-side">

            <!-- Logo + Card -->
            <div class="login-container">
                <div class="logo-container">
                    <img src="/images/logo.png" alt="Logo">
                </div>

                <div class="login-card">
                    <h2>Admin Login</h2>

                    <% if (message) { %>
  <div style="color:#ff2b8a; text-align:center; margin-bottom:15px;"><%= message %></div>
<% } %>

                            <form action="/" method="POST">
  <div class="input-group">
    <input type="text" name="identifier" placeholder="Enter Email or Username" required>
    <i class="fas fa-envelope"></i>
  </div>

  <div class="input-group">
    <input type="password" name="user_password" placeholder="Enter Password" required>
    <i class="fas fa-lock"></i>
  </div>

  <div class="remember">
    <input type="checkbox" name="remember"> Remember Me
  </div>

  <button type="submit" class="login-btn">Sign In</button>
</form>
                </div>
            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="right-side" id="rightSide">
            <!-- Balls will appear here -->
        </div>

    </div>

    <script>
        const rightSide = document.getElementById('rightSide');
        const colors = ["#ff2b8a", "#ff3aa6", "#6ee28e", "#fbc02d", "#42a5f5", "#ab47bc", "#ff7043"];

        for (let i = 0; i < 12; i++) { // 12 balls
            const ball = document.createElement('div');
            ball.classList.add('ball');

            const size = 40 + Math.random() * 60;
            ball.style.width = size + 'px';
            ball.style.height = size + 'px';
            ball.style.background = colors[Math.floor(Math.random() * colors.length)];
            ball.style.top = Math.random() * 100 + '%';
            ball.style.left = Math.random() * 100 + '%';

            const x = (Math.random() * 200 - 100) + 'px'; // random movement
            const y = (Math.random() * 200 - 100) + 'px';
            ball.style.setProperty('--x', x);
            ball.style.setProperty('--y', y);
            ball.style.animationDuration = (3 + Math.random() * 3) + 's';

            rightSide.appendChild(ball);
        }
    </script>

</body>

</html>