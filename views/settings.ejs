<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="page-header">
    <h1 style="font-size: 24px; font-weight: 800; color: #111; margin-bottom: 4px;">Settings</h1>
    <p style="color: #666; font-size: 14px;">Manage your account, profile, and preferences</p>
</div>

<div class="tab-bar" style="margin-bottom: 24px; border-bottom: 1px solid #eaeef3; padding-bottom: 12px;">
    <a href="#" class="tab active" onclick="switchTab('profile', this)">Profile</a>
    <a href="#" class="tab" onclick="switchTab('company', this)">Company Configurations</a>
</div>

<!-- PROFILE TAB -->
<div id="tab-profile">
    <div class="card" style="margin-bottom: 24px; border-radius: 12px;">
        <h3 style="font-size: 18px; font-weight: 700; color: #111; margin-bottom: 20px;">Profile Settings</h3>
        <form id="profileForm">
            <div class="form-group" style="margin-bottom: 16px;">
                <label style="display:block; font-size:13px; font-weight:600; color:#444; margin-bottom:8px;">Full Name</label>
                <input type="text" name="name" value="<%= user.name %>" placeholder="Your Name" style="width:100%; padding:10px 14px; border:1px solid #e1e4e8; border-radius:8px; font-size:14px; outline:none;" required>
            </div>
            <div class="form-group" style="margin-bottom: 16px;">
                <label style="display:block; font-size:13px; font-weight:600; color:#444; margin-bottom:8px;">Email</label>
                <input type="email" name="email" value="<%= user.email %>" placeholder="you@example.com" style="width:100%; padding:10px 14px; border:1px solid #e1e4e8; border-radius:8px; font-size:14px; outline:none;" required>
            </div>
            <div class="form-group" style="margin-bottom: 24px;">
                <label style="display:block; font-size:13px; font-weight:600; color:#444; margin-bottom:8px;">Avatar URL</label>
                <input type="text" name="avatar" value="<%= user.image %>" placeholder="Paste image URL" style="width:100%; padding:10px 14px; border:1px solid #e1e4e8; border-radius:8px; font-size:14px; outline:none;">
            </div>
            <button type="submit" style="width:100%; padding:12px; background:#f72c91; color:#fff; font-weight:600; font-size:14px; border:none; border-radius:8px; cursor:pointer;">Save Profile</button>
        </form>
    </div>

    <div class="card" style="border-radius: 12px;">
        <h3 style="font-size: 18px; font-weight: 700; color: #111; margin-bottom: 20px;">Account Settings</h3>
        <form id="passwordForm">
            <div class="form-group" style="margin-bottom: 16px;">
                <label style="display:block; font-size:13px; font-weight:600; color:#444; margin-bottom:8px;">Current Password</label>
                <input type="password" name="current_password" placeholder="••••••••" style="width:100%; padding:10px 14px; border:1px solid #e1e4e8; border-radius:8px; font-size:14px; outline:none;" required>
            </div>
            <div class="form-group" style="margin-bottom: 16px;">
                <label style="display:block; font-size:13px; font-weight:600; color:#444; margin-bottom:8px;">New Password</label>
                <input type="password" name="new_password" placeholder="••••••••" style="width:100%; padding:10px 14px; border:1px solid #e1e4e8; border-radius:8px; font-size:14px; outline:none;" required>
            </div>
            <div class="form-group" style="margin-bottom: 24px;">
                <label style="display:block; font-size:13px; font-weight:600; color:#444; margin-bottom:8px;">Confirm Password</label>
                <input type="password" name="confirm_password" placeholder="••••••••" style="width:100%; padding:10px 14px; border:1px solid #e1e4e8; border-radius:8px; font-size:14px; outline:none;" required>
            </div>
            <button type="submit" style="width:100%; padding:12px; background:#f72c91; color:#fff; font-weight:600; font-size:14px; border:none; border-radius:8px; cursor:pointer;">Update Password</button>
        </form>
    </div>
</div>

<!-- COMPANY TAB -->
<div id="tab-company" style="display:none;">
    <div class="card settings-card" style="border-radius: 12px;">
        <% if(company.company_logo){ %>
        <img src="/uploads/logos/<%= company.company_logo %>" alt="Logo" class="logo-preview" onerror="this.style.display='none'">
        <% } %>
        <form id="settingsForm" enctype="multipart/form-data">
            <div class="form-grid">
                <div class="form-group"><label>Company Name</label><input name="company_name" value="<%= company.company_name || '' %>"></div>
                <div class="form-group"><label>Slogan</label><input name="company_salogan" value="<%= company.company_salogan || '' %>"></div>
                <div class="form-group"><label>Email</label><input name="company_email" type="email" value="<%= company.company_email || '' %>"></div>
                <div class="form-group"><label>Mobile</label><input name="company_mobile" value="<%= company.company_mobile || '' %>"></div>
                <div class="form-group"><label>Phone</label><input name="company_phone" value="<%= company.company_phone || '' %>"></div>
                <div class="form-group"><label>Website</label><input name="company_web" value="<%= company.company_web || '' %>"></div>
                <div class="form-group"><label>City</label><input name="company_city" value="<%= company.company_city || '' %>"></div>
                <div class="form-group"><label>Country</label><input name="company_country" value="<%= company.company_country || '' %>"></div>
                <div class="form-group"><label>Currency Symbol</label><input name="company_currency" value="<%= company.company_currency || '' %>"></div>
                <div class="form-group"><label>Update Logo</label><input name="company_logo" type="file" accept="image/*"></div>
                <div class="form-group full"><label>Address</label><textarea name="company_address" rows="3"><%= company.company_address || '' %></textarea></div>
            </div>
            <button type="submit" class="btn-primary" style="margin-top:24px;width:100%;max-width:300px">Save Company Data</button>
        </form>
    </div>
</div>

<script>
function switchTab(tab, el) {
    if(el) {
        document.querySelectorAll('.tab-bar .tab').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
    }
    document.getElementById('tab-profile').style.display = tab === 'profile' ? 'block' : 'none';
    document.getElementById('tab-company').style.display = tab === 'company' ? 'block' : 'none';
}

document.getElementById('profileForm').addEventListener('submit', async function(e){
    e.preventDefault();
    const fd = new FormData(this);
    const r = await fetch('/api/profile', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(Object.fromEntries(fd))});
    const d = await r.json();
    alert(d.message);
    if(d.success) location.reload();
});

document.getElementById('passwordForm').addEventListener('submit', async function(e){
    e.preventDefault();
    const fd = new FormData(this);
    const r = await fetch('/api/password', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(Object.fromEntries(fd))});
    const d = await r.json();
    alert(d.message);
    if(d.success) this.reset();
});

document.getElementById('settingsForm').addEventListener('submit', async function(e){
    e.preventDefault();
    const fd = new FormData(this);
    const r = await fetch('/api/settings', {method:'POST', body:fd});
    const d = await r.json();
    if(d.success){ alert('Settings saved!'); location.reload(); } else alert(d.message);
});
</script>

<%- include('partials/footer') %>
