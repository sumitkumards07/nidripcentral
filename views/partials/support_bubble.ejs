<!-- Floating Support Bubble -->
<div class="fixed bottom-24 right-6 z-[60] flex flex-col items-end gap-3 pointer-events-none">
    <% if (locals.content && locals.content.length > 0 && locals.content[0].company_mobile) { %>
        <% 
            let mobile = locals.content[0].company_mobile.replace(/\D/g, ''); 
        %>
        <a href="/chatbot" class="pointer-events-auto w-14 h-14 bg-primary text-white rounded-full shadow-[0_12px_40px_rgba(0,0,0,0.1)] flex items-center justify-center animate-bounce-slow active:scale-90 transition-transform no-underline">
            <span class="material-symbols-outlined !text-3xl">chat_bubble</span>
        </a>
    <% } %>
</div>

<style>
    @keyframes bounce-slow {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
    .animate-bounce-slow {
        animation: bounce-slow 3s infinite ease-in-out;
    }
</style>
