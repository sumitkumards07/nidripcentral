<header class="header">
  <div class="breadcrumbs">Dashboard / <strong><%= activePage.charAt(0).toUpperCase() + activePage.slice(1) %></strong></div>
  <div class="header-row">
    <label for="sidebar-toggle" class="hamburger">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <h1>
        <%= activePage === 'dashboard' ? 'Admin Dashboard' : '' %>
        <%= activePage === 'orders' ? 'Manage Orders' : '' %>
        <%= activePage === 'products' ? 'Manage Products' : '' %>
        <%= activePage === 'users' ? 'Manage Customers' : '' %>
        <%= activePage === 'stocks' ? 'Manage Stock' : '' %>
        <%= activePage === 'reviews' ? 'Manage Reviews' : '' %>
        <%= activePage === 'tickets' ? 'Manage Support' : '' %>
        <%= activePage === 'settings' ? 'Global Settings' : '' %>
    </h1>
    
    <div class="header-controls">
      <div class="search">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
        <input type="text" placeholder="Search anything here" aria-label="Search">
      </div>
      
      <button class="notif" aria-label="Notifications">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" />
          <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" />
        </svg>
      </button>
      
      <!-- Auth Actions matching target logic -->
      <div class="auth-buttons" style="display:flex; gap:12px; align-items:center;">
        <button class="upgrade" style="padding:10px 18px; font-weight:600; color:var(--c1); background:#fff; border-radius:12px; cursor:pointer; font-size:14px;">Sign Up</button>
        <a href="/logout" class="upgrade" style="padding:10px 18px; font-weight:600; color:#fff; background:linear-gradient(135deg, var(--c1), var(--c3)); border-radius:12px; text-decoration:none; display:flex; align-items:center; gap:8px; font-size:14px; box-shadow:0 10px 25px rgba(253,33,94,0.3);">
          Logout
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="white" viewBox="0 0 24 24">
            <path d="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5a2 2 0 0 0-2 2v4h2V5h14v14H5v-4H3v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/>
          </svg>
        </a>
      </div>
      
    </div>
  </div>
</header>