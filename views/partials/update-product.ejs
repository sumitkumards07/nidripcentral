<div class="page-container">

    <div class="card">
        <h2 class="page-title">Update Product</h2>

        <form action="/products/update-product/<%= product.product_id %>" 
              method="POST" 
              enctype="multipart/form-data">

            <!-- Basic Information -->
            <div class="section">
                <h4 class="section-title">Basic Information</h4>

                <div class="form-grid">

                    <!-- Product Name -->
                    <div class="form-group">
                        <label>Product Name</label>
                        <input type="text" 
                               name="product_name" 
                               value="<%= product.product_name %>" 
                               required>
                    </div>

                    <!-- Category -->
                    <div class="form-group">
                        <label>Category</label>
                        <select name="category_id" required>
                            <option value="">Select Category</option>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat.category_id %>"
                                    <%= cat.category_id == product.category_id ? 'selected' : '' %>>
                                    <%= cat.category_name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <!-- Sub Category -->
                    <div class="form-group">
                        <label>Sub Category</label>
                        <select name="subcategory_id" required>
                            <option value="">Select Sub Category</option>
                            <% scats.forEach(scat => { %>
                                <option value="<%= scat.subcategory_id %>"
                                    <%= scat.subcategory_id == product.subcategory_id ? 'selected' : '' %>>
                                    <%= scat.subcategory_name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <!-- Unit -->
                    <div class="form-group">
                        <label>Product Unit</label>
                        <select name="unit_id" required>
                            <option value="">Select Unit</option>
                            <% units.forEach(unit => { %>
                                <option value="<%= unit.unit_id %>"
                                    <%= unit.unit_id == product.unit_id ? 'selected' : '' %>>
                                    <%= unit.unit_name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                </div>
            </div>

            <!-- Pricing -->
            <div class="section">
                <h4 class="section-title">Pricing</h4>

                <div class="form-grid">

                    <div class="form-group">
                        <label>Product Price ($)</label>
                        <input type="number" 
                               step="0.01" 
                               name="product_price" 
                               value="<%= product.product_price %>" 
                               required>
                    </div>

                    <div class="form-group">
                        <label>Old Price ($)</label>
                        <input type="number" 
                               step="0.01" 
                               name="product_old_price" 
                               value="<%= product.product_old_price %>">
                    </div>

                    <div class="form-group">
                        <label>Discount (%)</label>
                        <input type="number" 
                               name="product_discount" 
                               value="<%= product.product_discount %>">
                    </div>

                </div>
            </div>

            <!-- Media -->
            <div class="section">
                <h4 class="section-title">Media & Files</h4>

                <div class="form-grid">

                    <!-- Image Upload -->
                    <div class="form-group">
                        <label>Product Image</label>
                        <input type="file" name="product_image">

                        <% if(product.product_image) { %>
                            <div style="margin-top:10px;">
                                <img src="<%= product.product_image %>" 
                                     width="120" 
                                     style="border-radius:8px; border:1px solid #eee;">
                            </div>
                        <% } %>
                    </div>

                    <!-- Video -->
                    <div class="form-group">
                        <label>Product Video URL</label>
                        <input type="text" 
                               name="product_video" 
                               value="<%= product.product_video %>">
                    </div>

                    <!-- Status -->
                    <div class="form-group">
                        <label>Status</label>
                        <select name="product_status">
                            <option value="Active" 
                                <%= product.product_status === 'Active' ? 'selected' : '' %>>
                                Active
                            </option>
                            <option value="Inactive"
                                <%= product.product_status === 'Inactive' ? 'selected' : '' %>>
                                Inactive
                            </option>
                        </select>
                    </div>

                </div>
            </div>

            <!-- Product Details -->
            <div class="section">
                <h4 class="section-title">Product Details</h4>

                <div class="form-grid">

                    <div class="form-group full-width">
                        <label>Product Keywords</label>
                        <input type="text" 
                               name="product_keywords" 
                               value="<%= product.product_keywords %>" 
                               placeholder="Comma separated keywords">
                    </div>

                    <div class="form-group full-width">
                        <label>Product Description</label>
                        <textarea name="product_desc" 
                                  rows="4"><%= product.product_desc %></textarea>
                    </div>

                </div>
            </div>

            <div class="btn-wrapper">
                <button type="submit" class="btn-primary">
                    Update Product
                </button>
            </div>

        </form>
    </div>
</div>
<style>
.page-container {
    width: 100%;
    padding: 30px 40px;
    box-sizing: border-box;
}

/* Card */
.card {
    width: 100%;
    background: #fff;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 6px 25px rgba(0,0,0,0.08);
    border-top: 4px solid #bd04e2;
    border-bottom: 1px solid #bd04e2;
}

/* Titles */
.page-title {
    margin-bottom: 30px;
    font-weight: 600;
    color: #333;
}

.section {
    margin-bottom: 35px;
}

.section-title {
    margin-bottom: 15px;
    color: #bd04e2;
}

/* Grid Layout */
.form-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
}

/* Tablet */
@media (max-width: 1100px) {
    .form-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* Mobile */
@media (max-width: 600px) {
    .form-grid {
        grid-template-columns: 1fr;
    }
}

/* Form elements */
.form-group {
    display: flex;
    flex-direction: column;
}

.full-width {
    grid-column: span 3;
}

@media (max-width: 1100px) {
    .full-width {
        grid-column: span 2;
    }
}

@media (max-width: 600px) {
    .full-width {
        grid-column: span 1;
    }
}

label {
    font-size: 14px;
    margin-bottom: 6px;
    font-weight: 500;
}

input, textarea, select {
    padding: 10px 12px;
    border-radius: 6px;
    border: 1px solid #ddd;
    font-size: 14px;
}

input:focus, textarea:focus, select:focus {
    outline: none;
    border-color: #fd215e;
    box-shadow: 0 0 0 2px rgba(253,33,94,0.1);
}

/* Button */
.btn-wrapper {
    text-align: right;
}

.btn-primary {
    padding: 10px 25px;
    background-color: #fd215e;
    border: none;
    border-radius: 6px;
    color: #fff;
    font-weight: 600;
    cursor: pointer;
}

.btn-primary:hover {
    opacity: 0.9;
}
</style>