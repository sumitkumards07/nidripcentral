<section class="cards">
    <div class="card stat">
        <div class="icon" style="background:#bd04e2;"><i class="fa fa-object-group" style="font-size:2.0em;"></i></div>
        <div class="meta"><div class="label">Total Products</div><div class="value total_products">0</div></div>
    </div>
    <div class="card stat">
        <div class="icon" style="background:#bd04e2;"><i class="fa fa-shopping-basket" style="font-size:2.0em;"></i></div>
        <div class="meta"><div class="label">Sold Out</div><div class="value sold_out">0</div></div>
    </div>
    <div class="card stat">
        <div class="icon" style="background:#bd04e2;"><i class="fa fa-people-carry" style="font-size:2.0em;"></i></div>
        <div class="meta"><div class="label">Products Damaged</div><div class="value products_damaged">0</div></div>
    </div>
    <div class="card stat">
        <div class="icon" style="background:#bd04e2;"><i class="fa fa-store-alt" style="font-size:2.0em;"></i></div>
        <div class="meta"><div class="label">Products Available In Stock</div><div class="value products_in_stock">0</div></div>
    </div>
</section>

<div class="table-container" style="border-top: 2px solid #bd04e2; overflow: visible;">
    <a href="/products/add-product" style="text-decoration: none;padding: 8px;color: white;background: #bd04e2;float:right;border-radius: 8px;margin-right: 5px;">
        <i class="fa fa-plus"></i> Product
    </a>
    <a href="/products/add-subcategory" style="text-decoration: none;padding: 8px;color: white;background: #bd04e2;float:right;border-radius: 8px;margin-right: 5px;">
        <i class="fa fa-plus"></i> Sub Category
    </a>
    <a href="/products/add-category" style="text-decoration: none;padding: 8px;color: white;background: #bd04e2;float:right;border-radius: 8px;margin-right: 5px;">
        <i class="fa fa-plus"></i> Category
    </a>
    <a href="/products/add-unit" style="text-decoration: none;padding: 8px;color: white;background: #bd04e2;float:right;border-radius: 8px;margin-right: 5px;">
        <i class="fa fa-plus"></i> Unit
    </a>
    <table class="orders-table">
        <thead>
            <tr>
                <th>Product ID</th>
                <th>Image</th>
                <th>Product Name</th>
                <th>New Price</th>
                <th>Old Price</th>
                <th>Status</th>
                <th>Quick Action</th>
            </tr>
        </thead>
        <tbody>
            <% if(products.length === 0){ %>
                <tr><td colspan="8" style="text-align:center;">No products found</td></tr>
            <% } %>
            <% products.forEach(product => { %>
            <tr>
                <td><%= product.product_id %></td>
                <td>
                    <% if(product.product_image){ %><img src="<%= product.product_image %>" class="product-img" width="30">
                    <% } else { %><span class="no-img">No Image</span><% } %>
                </td>
                <td><%= product.product_name %></td>
                <td>$<%= product.product_price %></td>
                <td>$<%= product.product_old_price %></td>
                <td><span class="status-badge  <%= product.product_status === 'Active' ? 'active' : 'inactive' %>"><%= product.product_status %></span></td>
                <td class="action-cell">
                    <div class="dropdown">
                        <button class="action-btn">
                            <i class="fa-solid fa-ellipsis-vertical"></i>
                        </button>
                        <div class="dropdown-menu">
                            <a href="/products/view-product/<%= product.product_id %>"><i class="fa fa-eye"></i> View Details</a>
                            <a href="/products/update-product/<%= product.product_id %>"><i class="fa fa-edit"></i> Update Product</a>
                            <a href="/products/delete-product/<%= product.product_id %>" onclick="return confirm('Are you sure you want to delete this product?')" class="danger"><i class="fa fa-trash"></i> Delete Product</a>
                        </div>
                    </div>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<style>
    .action-cell {position: relative;}
    .dropdown {position: relative; display: inline-block; }
    .action-btn {background: none;border: none;font-size: 18px;cursor: pointer;padding: 6px 10px;border-radius: 6px;transition: background 0.2s ease;}
    .action-btn:hover {background: rgba(0, 0, 0, 0.05);}
    .dropdown-menu {
        position: absolute;bottom: 110%;right: 0;background: rgba(120, 120, 120, 0.3);backdrop-filter: blur(8px);-webkit-backdrop-filter: blur(8px);
        border-radius: 12px;min-width: 250px;padding: 8px 0;box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);opacity: 0;visibility: hidden;
        transform: translateY(10px);transition: 0.2s ease;z-index: 100;
    }
    .dropdown-menu a {display: block;padding: 10px 16px; font-size: 12px; color: #222;text-decoration: none;transition: background 0.2s ease;}
    .dropdown-menu a:hover {background: rgba(0, 0, 0, 0.08);}
    .dropdown-menu .danger {color: #e63946;}
    .dropdown.active .dropdown-menu { opacity: 1;visibility: visible;transform: translateY(0);}
</style>

<script>
    document.addEventListener("click", function (e) { const dropdowns = document.querySelectorAll(".dropdown");
        dropdowns.forEach(drop => {
            if (drop.contains(e.target)) { drop.classList.toggle("active"); } else { drop.classList.remove("active"); }
        });
    });
</script>