    <header class="header"
        style="padding: 12px 32px 24px; border-bottom: none; display: flex; align-items: center; justify-content: space-between; background: #f6f8fa; position: sticky; top: 0; z-index: 50;">
        <label for="sidebar-toggle" class="hamburger" style="display: none; padding: 8px; cursor: pointer;">
            <span style="display:block; width:22px; height:2px; background:#111; margin-bottom:5px;"></span>
            <span style="display:block; width:22px; height:2px; background:#111; margin-bottom:5px;"></span>
            <span style="display:block; width:22px; height:2px; background:#111;"></span>
        </label>

        <h1 style="font-size: 26px; font-weight: 800; color: #111; margin: 0;">Admin Dashboard</h1>

        <div class="header-right" style="display: flex; align-items: center; gap: 12px; margin-left: auto;">
            <div class="search-box" style="position: relative; display: flex; align-items: center;">
                <svg style="position: absolute; left: 16px; color: #aaa;" width="18" height="18" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.3-4.3" />
                </svg>
                <input type="text" placeholder="Search anything here"
                    style="padding: 10px 16px 10px 42px; border: 1px solid #eee; border-radius: 24px; outline: none; width: 260px; font-size: 14px; background: #fff;">
            </div>
            <button class="btn-icon"
                style="background:#f72c91; color:#fff; border:none; width:40px; height:40px; border-radius:12px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" />
                    <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" />
                </svg>
            </button>
            <a href="#" class="btn-solid"
                style="background:#f72c91; color:#fff; padding:10px 20px; border-radius:24px; font-weight:600; font-size:14px;">Sign
                Up</a>
