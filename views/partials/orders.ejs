<section class="cards">
    <div class="card stat">
        <div class="icon"><i class="fa fa-clipboard" style="font-size:2.0em;"></i></div>
        <div class="meta"><div class="label">Total Orders</div><div class="value total_orders">0</div></div>
    </div>
    <div class="card stat">
        <div class="icon"><i class="fa fa-truck" style="font-size:2.0em;"></i></div>
        <div class="meta"><div class="label">Pending Orders</div><div class="value pending_orders">0</div></div>
    </div>
    <div class="card stat">
        <div class="icon"><i class="fa fa-check-square" style="font-size:2.0em;"></i></div>
        <div class="meta"><div class="label">Order Delivered</div><div class="value delivered_orders">0</div></div>
    </div>
    <div class="card stat">
        <div class="icon"><i class="fa fa-beer" style="font-size:2.0em;"></i></div>
        <div class="meta"><div class="label">Return / Refund Requests</div><div class="value return_orders">0</div></div>
    </div>
</section>

<div class="table-container" style="border-top: 2px solid #fd215e; overflow: visible;">
    <table class="orders-table">
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Order Date</th>
                <th>Customer Name</th>
                <th>Product Name</th>
                <th>Amount</th>
                <th>Payment Method</th>
                <th>Status</th>
                <th>Quick Action</th>
            </tr>
        </thead>
        <tbody>
            <% if (orders.length > 0) { %>
                <% orders.forEach(order => { %>
                    <tr>
                        <td><%= order.id %></td>
                        <td><%= new Date(order.date).toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" }) %></td>
                        <td><%= order.user_name || "Guest" %></td>
                        <td><%= order.product_name %></td>
                        <td>$<%= Number(order.total_amount).toFixed(2) %></td>
                        <td>Cash</td>
                        <td>
                            <% if(order.status === "Pending") { %><span class="badge badge-pending">Pending</span>
                            <% } else if(order.status === "Placed") { %><span class="badge badge-placed">Placed</span>
                            <% } else if(order.status === "Processing") { %><span class="badge badge-processing">Processing</span>
                            <% } else if(order.status === "Delivered") { %><span class="badge badge-delivered">Delivered</span>
                            <% } else if(order.status === "Returned") { %><span class="badge badge-returned">Returned</span>
                            <% } else if(order.status === "Cancelled") { %><span class="badge badge-cancelled">Cancelled</span><% } %>
                        </td>
                        <td class="action-cell">
                            <div class="dropdown">
                                <button class="action-btn">
                                    <i class="fa-solid fa-ellipsis-vertical"></i>
                                </button>
                                <div class="dropdown-menu">
                                    <a href="/orders/view-order-detail/<%= order.id %>">
                                        <i class="fa fa-eye"></i> View Details
                                    </a>
                                    <a href="/orders/change-order-status/<%= order.id %>">
                                        <i class="fa fa-eye"></i> Change Order Status
                                    </a>
                                    <a href="/orders/update-payment-status/<%= order.id %>">
                                        <i class="fa fa-credit-card"></i> Update Payment Status
                                    </a>
                                    <a href="/orders/delete/<%= order.id %>" class="danger">
                                        <i class="fa fa-trash"></i> Delete Order
                                    </a>
                                </div>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr><td colspan="8" style="text-align:center;">No Orders Found</td></tr>
            <% } %>
        </tbody>
    </table>
</div>



<style>
    .action-cell {position: relative;}
    .dropdown {position: relative; display: inline-block; }
    .action-btn {background: none;border: none;font-size: 18px;cursor: pointer;padding: 6px 10px;border-radius: 6px;transition: background 0.2s ease;}
    .action-btn:hover {background: rgba(0, 0, 0, 0.05);}
    .dropdown-menu {
        position: absolute;bottom: 110%;right: 0;background: rgba(120, 120, 120, 0.3);backdrop-filter: blur(8px);-webkit-backdrop-filter: blur(8px);
        border-radius: 12px;min-width: 250px;padding: 8px 0;box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);opacity: 0;visibility: hidden;
        transform: translateY(10px);transition: 0.2s ease;z-index: 100;
    }
    .dropdown-menu a {display: block;padding: 10px 16px; font-size: 12px; color: #222;text-decoration: none;transition: background 0.2s ease;}
    .dropdown-menu a:hover {background: rgba(0, 0, 0, 0.08);}
    .dropdown-menu .danger {color: #e63946;}
    .dropdown.active .dropdown-menu { opacity: 1;visibility: visible;transform: translateY(0);}
    .badge {padding: 6px 12px;font-size: 12px;font-weight: 600;border-radius: 20px;display: inline-block;text-align: center;min-width: 90px;}
    .badge-pending {background: #fff3cd;color: #856404;}
    .badge-placed {background: #d1ecf1;color: #0c5460;}
    .badge-processing {background: #cce5ff;color: #004085;}
    .badge-delivered {background: #d4edda;color: #155724;}
    .badge-returned {background: #f8d7da;color: #721c24;}
    .badge-cancelled {background: #f5c6cb;color: #721c24;}
</style>

<script>
    document.addEventListener("click", function (e) { const dropdowns = document.querySelectorAll(".dropdown");
        dropdowns.forEach(drop => {
            if (drop.contains(e.target)) { drop.classList.toggle("active"); } else { drop.classList.remove("active"); }
        });
    });
</script>
