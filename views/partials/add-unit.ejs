<div class="page-container-left">
    <div class="card">
        <h2 class="page-title">Add New Unit</h2>
        <form action="/products/add-unit" method="POST">
            <div class="section">
                <div class="form-group">
                    <label>Unit Name</label>
                    <input type="text" name="unit_name" placeholder="Enter unit name" required>
                    <input type="hidden" name="created_by" value="<% if(user) { %><%= user.user_name %><% } %>" />
                </div>
                <div class="form-group">
                    <label style="color:#fff;">--</label>
                    <button type="submit" class="btn-primary" style="background: var(--c1);">Save Unit</button><br>
                    <a href="/products" style="text-decoration: none;text-align: center;color: var(--c1);">Back to products</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="page-container-right">
    <div class="card">
        <h2 class="page-title">All Units</h2>
        <div class="section">
            <table style="width:100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="text-align:left; padding:8px;width:150px;">Unit ID</th>
                        <th style="text-align:left; padding:8px;width:150px;">Unit Name</th>
                        <th style="text-align:left; padding:8px;width:150px;">Created By</th>
                        <th style="text-align:left; padding:8px;width:150px;">Created On</th>
                        <th style="text-align:left; padding:8px;width:150px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(units && units.length > 0) { %>
                        <% units.forEach(unit => { %>
                            <tr>
                                <td style="padding:8px;width:150px;"><%= unit.unit_id %></td>
                                <td style="padding:8px;width:150px;"><%= unit.unit_name %></td>
                                <td style="padding:8px;width:150px;"><%= unit.created_by %></td>
                                <td style="padding:8px;width:150px;"><%= unit.created_on.toISOString().split('T')[0] %></td>
                                <td>
                                    <div class="dropdown">
                                        <button class="action-btn">
                                            <i class="fa-solid fa-ellipsis-vertical"></i>
                                        </button>
                                        <div class="dropdown-menu">
                                            <a href="/products/update-unit/<%= unit.unit_id %>"><i class="fa fa-edit"></i> Update Unit</a>
                                            <a href="/products/delete-unit/<%= unit.unit_id %>" onclick="return confirm('Are you sure you want to delete this unit?')" class="danger"><i class="fa fa-trash"></i> Delete Unit</a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="padding:8px; text-align:center;">No units found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<style>
    .dropdown { position: relative; display: inline-block;}
    .action-btn { background: none; border: none; cursor: pointer; font-size: 18px;}
    .dropdown-menu {
        position: absolute;bottom: 110%;right: 0;background: rgba(120, 120, 120, 0.3);backdrop-filter: blur(8px);-webkit-backdrop-filter: blur(8px);
        border-radius: 12px;min-width: 250px;padding: 8px 0;box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);opacity: 0;visibility: hidden;
        transform: translateY(10px);transition: 0.2s ease;z-index: 100;
    }
    .dropdown-menu a {display: block;padding: 10px 16px; font-size: 12px; color: #222;text-decoration: none;transition: background 0.2s ease;}
    .dropdown-menu a:hover {background: rgba(0, 0, 0, 0.08);}
    .dropdown-menu .danger {color: #e63946;}
    .dropdown.active .dropdown-menu { opacity: 1;visibility: visible;transform: translateY(0);}
.page-container-left {
    width: 40%;
    padding: 30px 40px;
    box-sizing: border-box;
    float: left;
}
.page-container-right {
    width: 60%;
    padding: 30px 40px;
    box-sizing: border-box;
    float: left;
}
.card {
    width: 100%;
    background: #fff;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 6px 25px rgba(0,0,0,0.08);
    border-top: 4px solid var(--c1);
    border-bottom: 1px solid var(--c1);
}
.page-title {
    margin-bottom: 30px;
    font-weight: 600;
    color: #333;
}
.section {
    margin-bottom: 35px;
}
.section-title {
    margin-bottom: 15px;
    color: var(--c1);
}
.form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
}
@media (max-width: 600px) {
    .form-grid {
        grid-template-columns: 1fr;
    }
}
.form-group {
    display: flex;
    flex-direction: column;
}
label {
    font-size: 14px;
    margin-bottom: 6px;
    font-weight: 500;
}
input {
    padding: 10px 12px;
    border-radius: 6px;
    border: 1px solid #ddd;
    font-size: 14px;
}
input:focus {
    outline: none;
    border-color: #fd215e;
    box-shadow: 0 0 0 2px rgba(253,33,94,0.1);
}
.btn-wrapper {
    text-align: right;
}
.btn-primary {
    padding: 10px 25px;
    background-color: #fd215e;
    border: none;
    border-radius: 6px;
    color: #fff;
    font-weight: 600;
    cursor: pointer;
}
.btn-primary:hover {
    opacity: 0.9;
}
</style>

<script>
    document.addEventListener("click", function (e) { const dropdowns = document.querySelectorAll(".dropdown");
        dropdowns.forEach(drop => {
            if (drop.contains(e.target)) { drop.classList.toggle("active"); } else { drop.classList.remove("active"); }
        });
    });
</script>