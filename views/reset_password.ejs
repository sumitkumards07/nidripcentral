<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NI DRIP - Reset Password</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body>
  <div class="mobile-frame">
    <div class="auth-bg">
      <button class="login-back-btn" onclick="window.location.href='/login'"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8L10 4" stroke="#1B1B1B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
      
      <h1 class="login-header-title">Reset Password</h1>

      <div class="forgot-password-container">
        <% if (locals.message) { %>
          <p style="color: red; font-family: 'Poppins', sans-serif; font-size: 14px;"><%= message %></p>
        <% } %>
        
        <p style="text-align: left; color: #4B4B4B; font-size: 14px; font-family: 'Poppins'; margin-bottom: 0;">
          Enter your new password below.
        </p>

        <form action="/reset-password" method="POST" style="width: 100%; display: flex; flex-direction: column; gap: 40px;">
          <input type="hidden" name="email" value="<%= email %>">
          <div class="login-form-group">
            <div class="login-input-wrapper">
              <label class="login-label">New Password</label>
              <input type="password" name="new_password" class="login-input" placeholder="Enter new password" required minlength="6">
            </div>
          </div>

          <button type="submit" class="auth-btn-primary" style="width: 100%;">Reset Password</button>
        </form>
      </div>

      <div class="flex-grow"></div>
      <div style="width: 134px; height: 5px; background: #000000; border-radius: 100px; margin: 0 auto 10px; opacity: 0.1;"></div>
    </div>
  </div>
</body>
</html>
