<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NI DRIP - My Orders</title>
  <link rel="stylesheet" href="/css/modern.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body style="background-color: #f5f5f5; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh;">
  <div class="mobile-frame">
    <div style="background: #fcfcfc; height: 100%; display: flex; flex-direction: column; position: relative; overflow: hidden;">
      
      <header class="shop-header">
        <button class="shop-back-btn" onclick="history.back()">
          <i class="fa-solid fa-arrow-left"></i>
        </button>
        <span style="font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 16px; color: #1A1A1A;">My Orders</span>
        <div style="width: 20px;"></div>
      </header>

      <div style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px; -ms-overflow-style: none; scrollbar-width: none;">
        <% if (orders.length === 0) { %>
          <div style="text-align: center; margin-top: 50px; color: #888; font-family: 'Poppins', sans-serif;">
            <i class="fa-solid fa-box-open" style="font-size: 48px; color: #ddd; margin-bottom: 16px;"></i>
            <p>You haven't placed any orders yet.</p>
            <a href="/shop" class="shop-add-cart-btn" style="display: inline-block; width: auto; padding: 10px 24px; text-decoration: none; margin-top: 16px;">Start Shopping</a>
          </div>
        <% } else { %>
          <% orders.forEach(order => { %>
            <div style="display: flex; gap: 16px; align-items: center; background: #fff; border: 1px solid #EBEBEB; border-radius: 16px; padding: 16px;">
              <div style="width: 60px; height: 60px; background: #F8F8F8; border-radius: 12px; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                <% if (order.product_image && order.product_image !== 'null') { %>
                  <img src="/images/<%= order.product_image %>" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                  <i class="fa-solid fa-box" style="display: none; color: #ddd; font-size: 20px;"></i>
                <% } else { %>
                  <i class="fa-solid fa-box" style="color: #ddd; font-size: 20px;"></i>
                <% } %>
              </div>
              
              <div style="flex: 1;">
                <h4 style="margin: 0 0 4px 0; font-family: 'Poppins', sans-serif; font-size: 14px; color: #1A1A1A; font-weight: 500;"><%= order.product_name %></h4>
                <div style="font-family: 'Poppins', sans-serif; font-size: 12px; color: #888; margin-bottom: 4px;">Qty: <%= order.qty %> · <%= order.payment_method || 'N/A' %></div>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                  <span style="font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 14px; color: #00DB72;">£<%= parseFloat(order.total_amount).toFixed(2) %></span>
                  <span style="font-family: 'Poppins', sans-serif; font-size: 11px; font-weight: 500; padding: 4px 10px; border-radius: 20px;
                    <% if (order.status === 'Processing') { %>
                      background: #FFF4E5; color: #FF9800;
                    <% } else if (order.status === 'Delivered') { %>
                      background: #E8F5E9; color: #4CAF50;
                    <% } else if (order.status === 'Cancelled') { %>
                      background: #FFEBEE; color: #F44336;
                    <% } else { %>
                      background: #F5F5F5; color: #666;
                    <% } %>
                  "><%= order.status %></span>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <div style="position: absolute; bottom: 8px; left: calc(50% - 67px); width: 134px; height: 5px; background: #000000; border-radius: 100px; opacity: 0.1;"></div>
    </div>
  </div>
  <style>div::-webkit-scrollbar { display: none; }</style>
</body>
</html>
