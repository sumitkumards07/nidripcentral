<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>My Orders | NI DRIP CENTRAL</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
</head>
<body class="bg-surface font-body text-on-surface antialiased">
    <header class="fixed top-0 w-full z-50 bg-[#F8F9FA]/85 backdrop-blur-xl shadow-sm border-b border-outline-variant/10 pt-12">
        <div class="flex items-center justify-between px-6 py-4 w-full">
            <button onclick="history.back()" class="active:scale-95 duration-200 text-[#000000]">
                <span class="material-symbols-outlined">arrow_back</span>
            </button>
            <h1 class="text-lg font-extrabold tracking-tighter text-[#000000] font-headline">MY ORDERS</h1>
            <div class="w-6"></div>
        </div>
    </header>

    <main class="pt-32 pb-32 px-6 max-w-4xl mx-auto">
        <% if (orders.length === 0) { %>
            <div class="text-center py-20 space-y-6">
                <span class="material-symbols-outlined !text-7xl text-outline-variant/30">inventory_2</span>
                <p class="text-on-surface-variant font-medium">You haven't placed any orders yet.</p>
                <a href="/shop" class="inline-block bg-secondary text-white px-8 py-3 rounded-xl font-bold no-underline">Start Shopping</a>
            </div>
        <% } else { %>
            <div class="space-y-4">
                <% orders.forEach(order => { %>
                    <div class="bg-white p-5 rounded-2xl border border-outline-variant/10 shadow-sm flex gap-5">
                        <div class="w-20 h-20 bg-surface-container-low rounded-xl overflow-hidden shrink-0">
                            <% if (order.product_image && order.product_image !== 'null') { %>
                                <img src="/images/<%= order.product_image %>" class="w-full h-full object-cover">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center text-outline-variant">
                                    <span class="material-symbols-outlined">image</span>
                                </div>
                            <% } %>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-start mb-1">
                                <h3 class="font-bold text-primary truncate pr-2"><%= order.product_name %></h3>
                                <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded bg-secondary/5 text-secondary"><%= order.status %></span>
                            </div>
                            <p class="text-[11px] text-on-surface-variant font-medium mb-3">Qty: <%= order.qty %> · <%= order.payment_method %></p>
                            <div class="flex justify-between items-end">
                                <span class="text-lg font-extrabold text-[#10B981]">£<%= parseFloat(order.total_amount).toFixed(2) %></span>
                                <span class="text-[10px] text-outline-variant"><%= new Date(order.date).toLocaleDateString() %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <!-- Navigation -->
    <nav class="fixed bottom-0 w-full z-50 bg-white/85 backdrop-blur-xl border-t border-outline-variant/10 pb-8">
        <div class="flex justify-around items-center max-w-4xl mx-auto">
            <a href="/home" class="flex flex-col items-center gap-1 text-on-surface-variant no-underline">
                <span class="material-symbols-outlined">home</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Home</span>
            </a>
            <a href="/shop" class="flex flex-col items-center gap-1 text-on-surface-variant no-underline">
                <span class="material-symbols-outlined">grid_view</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Shop</span>
            </a>
            <a href="/profile" class="flex flex-col items-center gap-1 text-secondary no-underline">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">person</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Profile</span>
            </a>
        </div>
    </nav>
</body>
</html>
