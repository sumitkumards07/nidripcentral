<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customers - NI DRIP Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
<input type="checkbox" id="sidebar-toggle" hidden>
<label for="sidebar-toggle" class="overlay"></label>
<div class="app">
    <%- include('partials/sidebar') %>
    <main class="main">
        <%- include('partials/header', { title: 'Customers' }) %>
        <section class="content-area">
            <!-- Stats -->
            <div class="stats-row" style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:28px;">
                <div class="stat-mini"><div class="stat-value" id="totalCount">0</div><div class="stat-label">Total</div></div>
                <div class="stat-mini"><div class="stat-value" id="activeCount">0</div><div class="stat-label">Approved</div></div>
                <div class="stat-mini"><div class="stat-value" id="pendingCount">0</div><div class="stat-label">Pending</div></div>
                <div class="stat-mini"><div class="stat-value" id="topBuyerEl">—</div><div class="stat-label">Top Buyer</div></div>
            </div>
            <div class="card">
                <h3 class="card-title">All Customers</h3>
                <input type="text" id="custSearch" class="form-control" style="max-width:300px;margin-bottom:16px;" placeholder="Search by name or email..." oninput="filterCust(this.value)">
                <div class="table-wrap">
                    <table class="data-table">
                        <thead><tr><th>Name</th><th>Email</th><th>Orders</th><th>Status</th><th>ID</th><th>Action</th></tr></thead>
                        <tbody id="custList"></tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>
</div>
<script>
const ADMIN_API = '/admin-api';
let allCust = [];

async function loadCust() {
    const res = await fetch(`${ADMIN_API}/customers`);
    const json = await res.json();
    allCust = json.data || [];
    document.getElementById('totalCount').textContent = allCust.length;
    document.getElementById('activeCount').textContent = allCust.filter(u => u.user_status === 'Approved').length;
    document.getElementById('pendingCount').textContent = allCust.filter(u => u.user_status !== 'Approved').length;
    const top = [...allCust].sort((a,b) => b.order_count - a.order_count)[0];
    document.getElementById('topBuyerEl').textContent = top ? top.user_name || top.user_email : '—';
    renderCust(allCust);
}

function renderCust(data) {
    const tbody = document.getElementById('custList');
    if (!data.length) { tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;color:#999;">No customers found.</td></tr>'; return; }
    tbody.innerHTML = data.map(u => `<tr>
        <td><strong>${u.user_name || u.user_fname || '—'}</strong></td>
        <td>${u.user_email}</td>
        <td>${u.order_count || 0}</td>
        <td>
            <select onchange="changeStatus(${u.user_id}, this.value)" class="status-select">
                ${['Approved','Pending','Suspended'].map(s => `<option value="${s}" ${u.user_status===s?'selected':''}>${s}</option>`).join('')}
            </select>
        </td>
        <td style="color:#aaa;">#${u.user_id}</td>
        <td class="actions">
            <button onclick="deleteCustomer(${u.user_id})" class="danger"><i class="fa fa-trash"></i></button>
        </td>
    </tr>`).join('');
}

function filterCust(q) {
    renderCust(allCust.filter(u => (u.user_name||'').toLowerCase().includes(q.toLowerCase()) || (u.user_email||'').toLowerCase().includes(q.toLowerCase())));
}

async function changeStatus(id, status) {
    await fetch(`${ADMIN_API}/customers/${id}/status`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ status }) });
    loadCust();
}

async function deleteCustomer(id) {
    if (!confirm('Delete this customer? This cannot be undone.')) return;
    await fetch(`${ADMIN_API}/customers/${id}`, { method:'DELETE' });
    loadCust();
}

loadCust();
</script>
<script src="/js/script.js"></script>
</body>
</html>
