<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Shop | NI DRIP CENTRAL</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
</head>
<body class="bg-surface font-body text-on-surface antialiased">
    <header class="fixed top-0 w-full z-50 bg-[#F8F9FA]/85 backdrop-blur-xl shadow-sm border-b border-outline-variant/10 pt-12">
        <div class="flex items-center justify-between px-6 py-4 w-full">
            <button onclick="history.back()" class="active:scale-95 duration-200 text-[#000000]">
                <span class="material-symbols-outlined">arrow_back</span>
            </button>
            <h1 class="text-lg font-extrabold tracking-tighter text-[#000000] font-headline">SHOP ALL</h1>
            <a href="/cart" class="active:scale-95 duration-200 text-[#000000] relative">
                <span class="material-symbols-outlined">shopping_cart</span>
                <% if (locals.cartCount && locals.cartCount > 0) { %>
                    <span class="absolute -top-1 -right-1 bg-secondary text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold font-sans"><%= locals.cartCount %></span>
                <% } %>
            </a>
        </div>
        
        <!-- Category Filter Strip -->
        <div class="flex overflow-x-auto gap-3 px-6 pb-4 hide-scrollbar">
            <a href="/shop" class="px-5 py-2 rounded-full whitespace-nowrap text-xs font-bold transition-all no-underline <%= !activeCategoryId ? 'bg-primary text-white' : 'bg-surface-container-high text-on-surface-variant' %>">All Products</a>
            <% categories.forEach(cat => { %>
                <a href="/shop?category_id=<%= cat.category_id %>" class="px-5 py-2 rounded-full whitespace-nowrap text-xs font-bold transition-all no-underline <%= activeCategoryId == cat.category_id ? 'bg-primary text-white' : 'bg-surface-container-high text-on-surface-variant' %>">
                    <%= cat.category_name %>
                </a>
            <% }) %>
        </div>
    </header>

    <main class="pt-48 pb-32 px-6 max-w-4xl mx-auto">
        <div class="grid grid-cols-2 gap-4">
            <% products.forEach(prod => { %>
                <a href="/product/<%= prod.product_id %>" class="group bg-white border border-outline-variant/20 rounded-2xl overflow-hidden shadow-sm flex flex-col no-underline active:scale-95 transition-all">
                    <div class="aspect-square bg-surface-container-lowest p-6 relative">
                        <% if (prod.product_image && prod.product_image !== 'null') { %>
                            <img class="w-full h-full object-contain mix-blend-multiply group-hover:scale-110 transition-transform duration-500" src="/uploads/<%= prod.product_image %>" alt="<%= prod.product_name %>" onerror="this.src='/images/placeholder.png'"/>
                        <% } else { %>
                            <div class="w-full h-full flex items-center justify-center text-outline-variant">
                                <span class="material-symbols-outlined text-4xl">image_not_supported</span>
                            </div>
                        <% } %>
                    </div>
                    <div class="p-4 flex flex-col flex-1">
                        <h4 class="text-xs font-bold text-primary mb-1 line-clamp-2"><%= prod.product_name %></h4>
                        <div class="mt-auto flex items-center justify-between">
                            <span class="text-sm font-extrabold text-primary">£<%= prod.product_price %></span>
                            <div class="w-8 h-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center">
                                <span class="material-symbols-outlined !text-xl">add</span>
                            </div>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
    </main>

    <!-- Bottom Nav -->
    <nav class="fixed bottom-0 w-full z-50 bg-white/85 backdrop-blur-xl border-t border-outline-variant/10 pb-8 px-6">
        <div class="flex justify-around items-center py-4">
            <a href="/home" class="flex flex-col items-center gap-1 text-on-surface-variant no-underline">
                <span class="material-symbols-outlined">home</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Home</span>
            </a>
            <a href="/shop" class="flex flex-col items-center gap-1 text-secondary no-underline">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">grid_view</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Shop</span>
            </a>
            <a href="/profile" class="flex flex-col items-center gap-1 text-on-surface-variant no-underline">
                <span class="material-symbols-outlined">person</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Account</span>
            </a>
        </div>
    </nav>

    <style>
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
    <%- include("partials/support_bubble") %>
</body>
</html>
