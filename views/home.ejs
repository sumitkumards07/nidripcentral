<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>NI Drip Central - Electronics</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-tertiary": "#ffffff",
                        "on-primary-fixed-variant": "#404758",
                        "surface-container": "#edeeef",
                        "secondary-fixed-dim": "#c3c0ff",
                        "on-secondary-container": "#fffbff",
                        "tertiary": "#000000",
                        "on-secondary-fixed": "#0f0069",
                        "on-primary": "#ffffff",
                        "secondary-fixed": "#e2dfff",
                        "on-tertiary-container": "#968065",
                        "primary": "#000000",
                        "error": "#ba1a1a",
                        "surface-tint": "#575e70",
                        "surface-container-lowest": "#ffffff",
                        "primary-fixed-dim": "#c0c6db",
                        "on-error": "#ffffff",
                        "secondary-container": "#645efb",
                        "inverse-primary": "#c0c6db",
                        "tertiary-fixed-dim": "#dcc2a4",
                        "tertiary-container": "#261906",
                        "surface-container-high": "#e7e8e9",
                        "secondary": "#4b41e1",
                        "inverse-on-surface": "#f0f1f2",
                        "tertiary-fixed": "#f9debf",
                        "on-surface-variant": "#45464c",
                        "on-secondary-fixed-variant": "#3323cc",
                        "outline": "#76777d",
                        "on-primary-fixed": "#141b2b",
                        "surface-variant": "#e1e3e4",
                        "surface": "#f8f9fa",
                        "on-secondary": "#ffffff",
                        "surface-dim": "#d9dadb",
                        "inverse-surface": "#2e3132",
                        "surface-container-highest": "#e1e3e4",
                        "outline-variant": "#c6c6cd",
                        "surface-container-low": "#f3f4f5",
                        "primary-container": "#141b2b",
                        "on-surface": "#191c1d",
                        "on-tertiary-fixed-variant": "#55442d",
                        "surface-bright": "#f8f9fa",
                        "error-container": "#ffdad6",
                        "on-error-container": "#93000a",
                        "background": "#f8f9fa",
                        "on-primary-container": "#7d8497",
                        "primary-fixed": "#dce2f7",
                        "on-tertiary-fixed": "#261906",
                        "on-background": "#191c1d"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
        }
        h1, h2, h3, .font-headline {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="text-on-surface selection:bg-secondary/30">
<!-- Top Navigation Shell -->
<header class="fixed top-0 w-full z-50 bg-white/85 backdrop-blur-xl shadow-sm pt-12">
<div class="flex justify-between items-center px-6 h-16 w-full">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-black hover:opacity-80 transition-opacity active:scale-95 duration-200" data-icon="menu">menu</span>
<h1 class="text-lg font-extrabold text-black tracking-tighter font-headline">NI Drip Central</h1>
</div>
<div class="flex items-center gap-4">
<a href="/cart-view" class="active:scale-95 duration-200 text-[#000000] relative">
    <span class="material-symbols-outlined">shopping_cart</span>
    <% if (locals.cartCount && locals.cartCount > 0) { %>
        <span class="absolute -top-1 -right-1 bg-secondary text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold"><%= locals.cartCount %></span>
    <% } %>
</a>
</div>
</div>
</header>
<main class="pt-32 pb-24 px-6 max-w-md mx-auto min-h-screen">
<!-- Search Bar Section -->
<section class="mt-4 mb-8">
<form action="/search" method="GET" class="relative flex items-center">
<div class="absolute left-4 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-on-surface-variant text-[20px]" data-icon="search">search</span>
</div>
<input name="q" class="w-full h-12 pl-12 pr-4 bg-surface-container-low border-0 rounded-full text-on-surface placeholder:text-on-surface-variant/60 focus:ring-1 focus:ring-secondary/20 font-body text-sm" placeholder="Search appliances..." type="text"/>
</form>
</section>
<!-- Hero Banner Section -->
<section class="mb-6">
<div class="relative overflow-hidden rounded-[24px] bg-secondary aspect-[16/9] flex flex-col justify-center px-8 text-white shadow-xl">
<h2 class="text-2xl font-bold tracking-tight leading-tight mb-2 font-headline">Fast Delivery</h2>
<p class="text-white/80 text-sm font-body mb-6">Electronics & Appliances across Belfast</p>
<a href="/shop" class="w-fit px-6 py-2 bg-white text-secondary font-bold rounded-full text-sm no-underline">Shop All</a>
</div>
</section>
<!-- Trust Badge Section -->
<section class="flex justify-center mb-10">
<div class="inline-flex items-center gap-2 bg-surface-container-low px-4 py-2 rounded-full border border-outline-variant/10">
<span class="material-symbols-outlined text-[#10B981] text-[18px]">verified</span>
<span class="text-[10px] font-bold tracking-widest text-on-surface uppercase opacity-70">Official Partner Store</span>
</div>
</section>
<!-- Categories Section -->
<section class="mb-12">
<div class="flex justify-between items-baseline mb-6">
<h3 class="text-xl font-bold text-primary tracking-tight font-headline">Shop by Category</h3>
</div>
<div class="grid grid-cols-2 gap-4">
<% categories.forEach(cat => { %>
    <a href="/shop?category_id=<%= cat.category_id %>" class="group bg-white border border-outline-variant/30 rounded-xl p-4 flex flex-col gap-4 active:scale-[0.98] transition-all no-underline">
    <div class="bg-surface-container-low rounded-lg aspect-square flex items-center justify-center p-4">
    <img class="w-full h-full object-contain mix-blend-multiply opacity-90 group-hover:scale-110 transition-transform duration-500" alt="<%= cat.category_name %>" src="/images/<%= cat.category_image %>" onerror="this.src='https://via.placeholder.com/150?text=Category'"/>
    </div>
    <span class="text-sm font-semibold text-on-surface font-headline"><%= cat.category_name %></span>
    </a>
<% }) %>
</div>
</section>
<!-- Featured Products Section -->
<section class="mb-12 -mx-6">
<div class="px-6 flex justify-between items-baseline mb-6">
<h3 class="text-xl font-bold text-primary tracking-tight font-headline">Featured Products</h3>
<a href="/shop" class="text-xs font-semibold text-secondary uppercase tracking-widest font-label no-underline">View All</a>
</div>
<div class="flex overflow-x-auto gap-5 px-6 pb-4 hide-scrollbar">
<% products.forEach(prod => { %>
    <!-- Product Card -->
    <a href="/product/<%= prod.product_id %>" class="min-w-[240px] bg-white border border-outline-variant/20 rounded-2xl overflow-hidden flex flex-col shadow-sm no-underline">
    <div class="bg-surface-container-low aspect-[4/3] p-6 relative">
    <div class="absolute top-3 right-3 bg-white/80 backdrop-blur px-2 py-1 rounded-lg text-[10px] font-bold text-secondary border border-white/40 uppercase">Featured</div>
    <% if (prod.product_image && prod.product_image !== 'null') { %>
        <img class="w-full h-full object-contain mix-blend-multiply" alt="<%= prod.product_name %>" src="/uploads/<%= prod.product_image %>" onerror="this.src='https://via.placeholder.com/240x180?text=Product'"/>
    <% } else { %>
        <div class="w-full h-full flex items-center justify-center bg-surface-container-low text-outline-variant">
            <span class="material-symbols-outlined !text-6xl text-outline-variant/30">image_not_supported</span>
        </div>
    <% } %>
    </div>
    <div class="p-5 flex flex-col flex-1">
    <h4 class="text-sm font-semibold text-on-surface font-headline mb-1 line-clamp-1"><%= prod.product_name %></h4>
    <p class="text-[11px] text-on-surface-variant font-body mb-4">Fast Delivery</p>
    <div class="mt-auto flex items-center justify-between">
    <span class="text-lg font-bold text-primary font-headline">£<%= prod.product_price %></span>
    <form action="/cart/add" method="POST" class="m-0">
        <input type="hidden" name="product_id" value="<%= prod.product_id %>">
        <input type="hidden" name="qty" value="1">
        <input type="hidden" name="referer" value="/home">
        <button type="submit" class="p-2 bg-secondary text-white rounded-lg flex items-center justify-center hover:opacity-90 active:scale-90 transition-all">
            <span class="material-symbols-outlined text-[20px]">add_shopping_cart</span>
        </button>
    </form>
    </div>
    </div>
    </a>
<% }) %>
</div>
</section>
</main>
<!-- Bottom Navigation Shell -->
<nav class="fixed bottom-0 w-full z-50 rounded-t-2xl bg-white/85 backdrop-blur-xl shadow-[0_-4px_40px_rgba(0,0,0,0.04)] border-t border-slate-100 pb-8">
<div class="flex justify-around items-center h-20 px-4 w-full">
<a href="/home" class="flex flex-col items-center justify-center text-indigo-600 bg-indigo-50/50 rounded-xl px-3 py-1 active:scale-90 duration-200 no-underline">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">home</span>
<span class="font-headline text-[10px] font-semibold uppercase tracking-widest mt-1">Home</span>
</a>
<a href="/shop" class="flex flex-col items-center justify-center text-slate-400 px-3 py-1 hover:text-black transition-colors active:scale-90 duration-200 no-underline">
<span class="material-symbols-outlined">grid_view</span>
<span class="font-headline text-[10px] font-semibold uppercase tracking-widest mt-1">Categories</span>
</a>
<div class="flex flex-col items-center justify-center text-slate-400 px-3 py-1 hover:text-black transition-colors active:scale-90 duration-200 cursor-pointer">
<span class="material-symbols-outlined">favorite</span>
<span class="font-headline text-[10px] font-semibold uppercase tracking-widest mt-1">Wishlist</span>
</div>
<a href="/profile" class="flex flex-col items-center justify-center text-slate-400 px-3 py-1 hover:text-black transition-colors active:scale-90 duration-200 no-underline">
<span class="material-symbols-outlined">person</span>
<span class="font-headline text-[10px] font-semibold uppercase tracking-widest mt-1">Account</span>
</a>
</div>
</nav>
    <%- include("partials/support_bubble") %>
</body></html>

