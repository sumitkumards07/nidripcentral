<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Order Success | NI DRIP CENTRAL</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
          tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                colors: {
                  "on-secondary-container": "#fffbff",
                  "secondary": "#4b41e1",
                  "on-surface": "#191c1d",
                  "surface": "#f8f9fa",
                  "primary": "#000000",
                  "background": "#f8f9fa",
                  "on-background": "#191c1d",
                  "outline-variant": "#c6c6cd"
                },
                fontFamily: {
                  "headline": ["Plus Jakarta Sans"],
                  "body": ["Inter"]
                }
              }
            }
          }
    </script>
</head>
<body class="bg-background font-body text-on-surface antialiased flex items-center justify-center min-h-screen px-6">
    <div class="max-w-md w-full text-center space-y-8 animate-in fade-in zoom-in duration-700">
        <!-- Success Animation -->
        <div class="relative inline-block">
            <div class="w-24 h-24 rounded-full bg-secondary/10 flex items-center justify-center animate-bounce">
                <span class="material-symbols-outlined !text-6xl text-secondary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
            </div>
            <div class="absolute -top-1 -right-1 w-6 h-6 bg-[#10B981] rounded-full border-4 border-white flex items-center justify-center">
                <span class="material-symbols-outlined !text-xs text-white">sparkles</span>
            </div>
        </div>

        <div class="space-y-4">
            <h1 class="text-4xl font-headline font-extrabold tracking-tighter text-primary">Order Received!</h1>
            <p class="text-on-surface-variant font-medium">Thank you for your order. We will notify you once it has been shipped.</p>
        </div>

        <div class="bg-white p-6 rounded-3xl border border-outline-variant/10 shadow-sm space-y-4">
            <div class="flex justify-between items-center text-sm">
                <span class="text-on-surface-variant font-bold uppercase tracking-widest">Status</span>
                <span class="text-secondary font-bold uppercase tracking-tighter">Confirmed</span>
            </div>
        </div>

        <div class="pt-8 space-y-4">
            <a href="/home" class="block w-full bg-secondary text-white py-5 rounded-2xl font-headline font-extrabold text-lg shadow-lg shadow-secondary/20 active:scale-[0.98] transition-all no-underline">
                Continue Shopping
            </a>
            <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">Check your email for details</p>
        </div>
    </div>
</body>
</html>

