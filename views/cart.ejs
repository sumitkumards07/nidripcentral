<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Shopping Cart | NI DRIP CENTRAL</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@300;400;500;600&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-primary-fixed": "#141b2b",
                        "surface-container": "#edeeef",
                        "primary-fixed-dim": "#c0c6db",
                        "tertiary-container": "#261906",
                        "on-secondary-container": "#fffbff",
                        "on-surface": "#191c1d",
                        "on-error": "#ffffff",
                        "outline-variant": "#c6c6cd",
                        "tertiary": "#000000",
                        "surface-dim": "#d9dadb",
                        "primary-container": "#141b2b",
                        "secondary": "#4b41e1",
                        "inverse-primary": "#c0c6db",
                        "on-secondary": "#ffffff",
                        "on-tertiary-container": "#968065",
                        "on-primary": "#ffffff",
                        "primary-fixed": "#dce2f7",
                        "inverse-on-surface": "#f0f1f2",
                        "error-container": "#ffdad6",
                        "secondary-container": "#645efb",
                        "surface-container-highest": "#e1e3e4",
                        "secondary-fixed": "#e2dfff",
                        "on-tertiary-fixed": "#261906",
                        "on-surface-variant": "#45464c",
                        "on-primary-fixed-variant": "#404758",
                        "secondary-fixed-dim": "#c3c0ff",
                        "primary": "#000000",
                        "tertiary-fixed-dim": "#dcc2a4",
                        "surface-container-high": "#e7e8e9",
                        "tertiary-fixed": "#f9debf",
                        "outline": "#76777d",
                        "surface-variant": "#e1e3e4",
                        "surface-tint": "#575e70",
                        "surface": "#f8f9fa",
                        "surface-bright": "#f8f9fa",
                        "on-tertiary": "#ffffff",
                        "on-secondary-fixed-variant": "#3323cc",
                        "on-error-container": "#93000a",
                        "on-secondary-fixed": "#0f0069",
                        "on-tertiary-fixed-variant": "#55442d",
                        "inverse-surface": "#2e3132",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-low": "#f3f4f5",
                        "on-primary-container": "#7d8497",
                        "on-background": "#191c1d",
                        "background": "#f8f9fa",
                        "error": "#ba1a1a"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 200, 'GRAD' 0, 'opsz' 24;
        }
        .glass-header {
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #F8F9FA;
        }
        h1, h2, h3 {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface text-on-surface">
<!-- Top Navigation Bar -->
<header class="fixed top-0 w-full z-50 bg-[#F8F9FA]/85 backdrop-blur-xl shadow-sm pt-12">
<div class="flex items-center justify-between px-6 py-4 w-full">
<button onclick="history.back()" class="text-[#000000] active:scale-95 duration-200 transition-opacity hover:opacity-70">
<span class="material-symbols-outlined" data-icon="arrow_back">arrow_back</span>
</button>
<div class="font-['Plus_Jakarta_Sans'] font-bold tracking-tight text-lg font-extrabold tracking-tighter text-[#000000]">
                NI DRIP CENTRAL
            </div>
<button class="text-[#000000] active:scale-95 duration-200 transition-opacity hover:opacity-70 relative">
<span class="material-symbols-outlined" data-icon="shopping_bag">shopping_bag</span>
<% if (items.length > 0) { %>
<span class="absolute -top-1 -right-1 bg-secondary text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold"><%= items.length %></span>
<% } %>
</button>
</div>
<div class="bg-[#F3F4F5] h-[1px] w-full"></div>
</header>
<main class="pt-32 pb-32 px-6 max-w-3xl mx-auto">
<!-- Editorial Header -->
<div class="mb-12 mt-4 ml-8">
<h1 class="text-[3.5rem] leading-none font-extrabold tracking-tight text-primary mb-2">Cart</h1>
<p class="text-on-surface-variant font-body tracking-wide"><%= items.length %> premium curated items</p>
</div>

<!-- Cart Items List -->
<div class="space-y-12">
<% if (items.length === 0) { %>
    <div class="text-center py-20 flex flex-col items-center gap-6 bg-surface-container-lowest rounded-3xl border border-dashed border-outline-variant/30">
        <span class="material-symbols-outlined text-outline-variant/50 !text-6xl">shopping_cart_off</span>
        <div>
            <h3 class="text-xl font-bold text-primary mb-2">Your cart is empty</h3>
            <p class="text-on-surface-variant max-w-[240px] mx-auto text-sm">Discover our latest collection and start curating your style.</p>
        </div>
        <a href="/shop" class="bg-primary text-white px-8 py-3 rounded-xl font-bold active:scale-95 transition-transform">Start Shopping</a>
    </div>
<% } else { %>
    <% items.forEach(item => { %>
        <!-- Item Card -->
        <div class="group relative flex flex-col md:flex-row gap-6 md:items-center bg-white p-6 rounded-2xl border border-outline-variant/10 shadow-sm">
        <div class="relative w-full md:w-32 h-32 overflow-hidden rounded-xl bg-surface-container-low shrink-0">
            <% if (item.product_image && item.product_image !== 'null') { %>
                <img src="/images/<%= item.product_image %>" alt="<%= item.product_name %>" class="w-full h-full object-cover"/>
            <% } else { %>
                <div class="w-full h-full flex items-center justify-center bg-surface-container-low text-outline-variant">
                    <span class="material-symbols-outlined text-4xl">image</span>
                </div>
            <% } %>
        </div>
        <div class="flex-1 space-y-1">
            <div class="flex justify-between items-start">
                <h3 class="text-lg font-bold text-primary"><%= item.product_name %></h3>
                <form action="/cart/remove/<%= item.cart_id %>" method="POST" class="m-0">
                    <button type="submit" class="text-error/60 hover:text-error transition-colors p-2">
                        <span class="material-symbols-outlined">delete</span>
                    </button>
                </form>
            </div>
            <div class="flex items-center justify-between pt-2">
                <div class="text-sm font-medium text-on-surface-variant">
                    Quantity: <span class="font-bold text-primary"><%= item.qty %></span>
                </div>
                <div class="text-lg font-extrabold text-[#10B981]">£<%= parseFloat(item.product_price).toFixed(2) %></div>
            </div>
        </div>
        </div>
    <% }) %>
<% } %>
</div>

<% if (items.length > 0) { %>
<!-- Summary Section -->
<section class="mt-16 pt-8 border-t border-outline-variant/20 space-y-6">
<div class="flex justify-between items-center px-4">
<span class="text-on-surface-variant font-medium">Subtotal</span>
<span class="text-primary font-bold">£<%= total.toFixed(2) %></span>
</div>
<div class="flex justify-between items-center px-4">
<span class="text-on-surface-variant font-medium">Delivery Fee</span>
<span class="text-[#10B981] font-bold">FREE</span>
</div>
<div class="bg-surface-container p-6 rounded-xl flex justify-between items-center">
<span class="text-lg font-bold text-primary">Total Amount</span>
<span class="text-2xl font-extrabold text-primary">£<%= total.toFixed(2) %></span>
</div>
</section>
<!-- Primary Action Button -->
<div class="mt-12 px-4">
<a href="/checkout" class="w-full bg-[#4B41E1] text-white py-5 rounded-xl font-bold text-lg shadow-lg hover:bg-secondary-container active:scale-[0.98] transition-all duration-300 flex items-center justify-center gap-3 no-underline">
                Proceed to Checkout
                <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
</a>
</div>
<% } %>
</main>
<!-- Bottom Navigation Bar -->
<nav class="fixed bottom-0 w-full z-50 bg-[#FFFFFF]/85 backdrop-blur-2xl rounded-t-[16px] shadow-[0_-12px_40px_rgba(25,28,29,0.04)] border-t border-[#F3F4F5]/10 md:hidden">
<div class="flex justify-around items-center h-20 px-8 pb-safe">
<a href="/home" class="flex flex-col items-center justify-center text-[#45464C]">
<span class="material-symbols-outlined text-2xl" data-icon="home">home</span>
</a>
<a href="/shop" class="flex flex-col items-center justify-center text-[#45464C]">
<span class="material-symbols-outlined text-2xl" data-icon="search">search</span>
</a>
<div class="flex flex-col items-center justify-center text-[#4B41E1] scale-110">
<span class="material-symbols-outlined text-2xl font-bold" data-icon="receipt_long" style="font-variation-settings: 'FILL' 1;">receipt_long</span>
</div>
<a href="/profile" class="flex flex-col items-center justify-center text-[#45464C]">
<span class="material-symbols-outlined text-2xl" data-icon="person">person</span>
</a>
</div>
</nav>
<!-- Responsive Desktop Sidenav Hint -->
<aside class="hidden md:flex fixed left-0 top-0 h-full w-20 flex-col items-center py-12 bg-surface-container-lowest border-r border-outline-variant/10">
<div class="space-y-12">
<a href="/home" class="material-symbols-outlined text-[#45464C] cursor-pointer no-underline" data-icon="home">home</a>
<a href="/shop" class="material-symbols-outlined text-[#45464C] cursor-pointer no-underline" data-icon="search">search</a>
<span class="material-symbols-outlined text-[#4B41E1]" data-icon="receipt_long" style="font-variation-settings: 'FILL' 1;">receipt_long</span>
<a href="/profile" class="material-symbols-outlined text-[#45464C] cursor-pointer no-underline" data-icon="person">person</a>
</div>
</aside>
    <%- include("partials/support_bubble") %>
</body></html>

