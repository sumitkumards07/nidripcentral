<%- include('partials/header') %>
    <%- include('partials/sidebar') %>

        <div class="page-header">
            <h1>Brand Management</h1>
            <p>Add and manage product brands</p>
        </div>

        <div class="tab-bar" style="margin-bottom: 24px; border-bottom: 1px solid #eaeef3; padding-bottom: 12px;">
            <a href="/banners" class="tab">Banners</a>
            <a href="/brands" class="tab active">Brands</a>
            <a href="/categories" class="tab">Categories & Units</a>
        </div>

        <div class="card" style="margin-bottom:24px">
            <h3 class="card-title">Add New Brand</h3>
            <form id="brandForm" enctype="multipart/form-data">
                <div class="form-row-inline">
                    <div class="form-group"><label>Brand Name</label><input name="brand_name"
                            placeholder="Enter brand name" required></div>
                    <div class="form-group"><label>Brand Image</label><input name="brand_image" type="file"
                            accept="image/*" required></div>
                    <button type="submit" class="btn-primary" style="align-self:end">Add Brand</button>
                </div>
            </form>
        </div>

        <div class="brand-grid">
            <% brands.forEach(function(b){ %>
                <div class="brand-card">
                    <img src="/uploads/brands/<%= b.brand_image %>" alt="<%= b.brand_name %>"
                        onerror="this.src='/css/placeholder.svg'">
                    <div class="brand-info">
                        <span class="brand-name">
                            <%= b.brand_name %>
                        </span>
                        <button class="btn-danger-sm" onclick="deleteItem('/api/brands/<%= b.brand_id %>')">×</button>
                    </div>
                </div>
                <% }); %>
                    <% if(!brands.length){ %>
                        <div class="empty-message">No brands yet. Add your first brand above!</div>
                        <% } %>
        </div>

        <script>
            document.getElementById('brandForm').addEventListener('submit', async function (e) {
                e.preventDefault();
                const fd = new FormData(this);
                const r = await fetch('/api/brands', { method: 'POST', body: fd });
                const d = await r.json();
                if (d.success) location.reload(); else alert(d.message);
            });
            async function deleteItem(url) { if (!confirm('Delete?')) return; const r = await fetch(url, { method: 'DELETE' }); const d = await r.json(); if (d.success) location.reload(); }
        </script>
        <%- include('partials/footer') %>