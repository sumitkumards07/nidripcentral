<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 24px;">
    <div>
        <h1 style="font-size: 24px; font-weight: 800; color: #111; margin-bottom: 4px;">Reports</h1>
        <p style="color: #666; font-size: 14px;">View detailed analytics and reports</p>
    </div>
    <div style="display: flex; gap: 12px;">
        <input type="text" placeholder="Search report..." style="padding: 8px 16px; border: 1px solid #ddd; border-radius: 8px; outline: none; width: 200px;">
        <select style="padding: 8px 16px; border: 1px solid #ddd; border-radius: 8px; outline: none; background: #fff;">
            <option>All Types</option>
            <option>Sales</option>
            <option>Customers</option>
            <option>Products</option>
        </select>
    </div>
</div>

<!-- STAT CARDS -->
<div class="stat-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 24px;">
    <div class="card" style="padding: 24px; text-align: center; border-radius: 12px;">
        <div style="color: #666; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Total Reports</div>
        <div style="font-size: 24px; font-weight: 800; color: #111;"><%= stats.total || 0 %></div>
    </div>
    <div class="card" style="padding: 24px; text-align: center; border-radius: 12px;">
        <div style="color: #666; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Sales Reports</div>
        <div style="font-size: 24px; font-weight: 800; color: #111;"><%= stats.sales || 0 %></div>
    </div>
    <div class="card" style="padding: 24px; text-align: center; border-radius: 12px;">
        <div style="color: #666; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Customer Reports</div>
        <div style="font-size: 24px; font-weight: 800; color: #111;"><%= stats.customers || 0 %></div>
    </div>
    <div class="card" style="padding: 24px; text-align: center; border-radius: 12px;">
        <div style="color: #666; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Product Reports</div>
        <div style="font-size: 24px; font-weight: 800; color: #111;"><%= stats.products || 0 %></div>
    </div>
</div>

<!-- DATA TABLE -->
<div class="card" style="padding: 0; overflow: hidden; border-radius: 16px;">
    <div style="overflow-x: auto;">
        <table class="tbl">
            <thead>
                <tr>
                    <th>Report ID</th>
                    <th>Type</th>
                    <th>Generated By</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if(reports && reports.length) { %>
                    <% reports.forEach(r => { 
                        let badgeClass = 'badge-solid-gray';
                        if(r.status === 'Pending') badgeClass = 'badge-solid-pink';
                        if(r.status === 'Processing') badgeClass = 'badge-solid-orange';
                        if(r.status === 'Completed') badgeClass = 'badge-solid-green';
                        
                        const d = new Date(r.created_on);
                        const dStr = !isNaN(d) ? d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : r.created_on;
                    %>
                    <tr>
                        <td style="font-weight: 600; color: #333;">#R<%= 1000 + r.report_id %></td>
                        <td style="font-weight: 500; color: #111;"><%= r.report_type %></td>
                        <td style="color: #444;"><%= r.generated_by %></td>
                        <td style="color: #555;"><%= dStr %></td>
                        <td><span class="activity-badge <%= badgeClass %>"><%= r.status %></span></td>
                        <td class="action-dots" style="cursor: pointer;" onclick="deleteReport('<%= r.report_id %>')">⋮</td>
                    </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="6" class="empty">No reports found.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
async function deleteReport(id){
    if(!confirm('Delete this report?')) return;
    const r = await fetch('/api/reports/'+id, {method:'DELETE'});
    const d = await r.json();
    if(d.success) location.reload();
    else alert(d.message);
}
</script>

<%- include('partials/footer') %>
