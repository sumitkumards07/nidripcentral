<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Support Center | NI DRIP CENTRAL</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
</head>
<body class="bg-surface font-body text-on-surface antialiased">
    <header class="fixed top-0 w-full z-50 bg-[#F8F9FA]/85 backdrop-blur-xl shadow-sm border-b border-outline-variant/10 pt-12">
        <div class="flex items-center justify-between px-6 py-4 w-full">
            <button onclick="history.back()" class="active:scale-95 duration-200 text-[#000000]">
                <span class="material-symbols-outlined">arrow_back</span>
            </button>
            <h1 class="text-lg font-extrabold tracking-tighter text-[#000000] font-headline">SUPPORT CENTER</h1>
            <div class="w-6"></div>
        </div>
    </header>

    <main class="pt-32 pb-32 px-6 max-w-4xl mx-auto space-y-10">
        <!-- New Ticket Section -->
        <section class="bg-white p-6 rounded-3xl border border-outline-variant/10 shadow-sm space-y-6">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary">add_circle</span>
                <h2 class="text-lg font-headline font-extrabold text-primary">Create New Ticket</h2>
            </div>
            
            <a href="/chatbot" class="block bg-indigo-50/50 p-6 rounded-3xl border border-indigo-100 flex items-center justify-between group no-underline active:scale-[0.98] transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-indigo-600 shadow-sm">
                        <span class="material-symbols-outlined !text-2xl">smart_toy</span>
                    </div>
                    <div>
                        <h3 class="font-headline font-extrabold text-indigo-900 leading-tight">Instant Help</h3>
                        <p class="text-xs text-indigo-600/70 font-medium tracking-wide font-body">Chat with our AI assistant</p>
                    </div>
                </div>
                <span class="material-symbols-outlined text-indigo-300 group-hover:translate-x-1 transition-transform">chevron_right</span>
            </a>
            
            <form action="/support/create" method="POST" class="space-y-4">
                <div class="space-y-2">
                    <label class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Subject</label>
                    <input type="text" name="subject" required placeholder="How can we help?" class="w-full bg-surface-container-low border-0 rounded-2xl px-5 py-4 focus:ring-1 focus:ring-secondary transition-all outline-none">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Message</label>
                    <textarea name="message" required rows="4" placeholder="Describe your issue in detail..." class="w-full bg-surface-container-low border-0 rounded-2xl px-5 py-4 focus:ring-1 focus:ring-secondary transition-all outline-none resize-none"></textarea>
                </div>
                <div class="flex gap-4">
                    <div class="flex-1 space-y-2">
                        <label class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Priority</label>
                        <select name="priority" class="w-full bg-surface-container-low border-0 rounded-xl px-5 py-3 focus:ring-1 focus:ring-secondary transition-all outline-none">
                            <option value="Normal">Normal</option>
                            <option value="High">High</option>
                            <option value="Urgent">Urgent</option>
                        </select>
                    </div>
                    <div class="flex-1 flex items-end">
                        <button type="submit" class="w-full bg-primary text-white font-headline font-bold py-3 rounded-xl active:scale-95 transition-all shadow-lg shadow-black/5">Submit Ticket</button>
                    </div>
                </div>
            </form>
        </section>

        <!-- Ticket History -->
        <section class="space-y-4">
            <h2 class="text-lg font-headline font-extrabold text-primary ml-2">Ticket History</h2>
            
            <% if (tickets.length === 0) { %>
                <div class="text-center py-10 bg-white rounded-3xl border border-dashed border-outline-variant/20">
                    <p class="text-on-surface-variant text-sm font-medium">No tickets found.</p>
                </div>
            <% } else { %>
                <div class="space-y-4">
                    <% tickets.forEach(ticket => { %>
                        <div class="bg-white p-5 rounded-2xl border border-outline-variant/10 shadow-sm space-y-3">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-bold text-primary truncate mb-1"><%= ticket.subject %></h3>
                                    <div class="flex items-center gap-2">
                                        <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full 
                                            <%= ticket.status === 'Open' ? 'bg-[#10B981]/10 text-[#10B981]' : 'bg-secondary/10 text-secondary' %>">
                                            <%= ticket.status %>
                                        </span>
                                        <span class="text-[10px] text-outline-variant font-bold uppercase tracking-widest"><%= ticket.priority %></span>
                                    </div>
                                </div>
                                <span class="text-[10px] text-outline-variant"><%= ticket.formatted_date %></span>
                            </div>
                            <p class="text-xs text-on-surface-variant leading-relaxed line-clamp-3"><%= ticket.message %></p>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </main>

    <!-- Bottom Nav -->
    <nav class="fixed bottom-0 w-full z-50 bg-white/85 backdrop-blur-xl border-t border-outline-variant/10 pb-8 px-6">
        <div class="flex justify-around items-center max-w-4xl mx-auto">
            <a href="/home" class="flex flex-col items-center gap-1 text-on-surface-variant no-underline">
                <span class="material-symbols-outlined">home</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Home</span>
            </a>
            <a href="/shop" class="flex flex-col items-center gap-1 text-on-surface-variant no-underline">
                <span class="material-symbols-outlined">grid_view</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Shop</span>
            </a>
            <a href="/profile" class="flex flex-col items-center gap-1 text-secondary no-underline">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">person</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Profile</span>
            </a>
        </div>
    </nav>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const urlParams = new URLSearchParams(window.location.search);
            const success = urlParams.get("success");
            const error = urlParams.get("error");
            if (success) Swal.fire({ icon: 'success', title: 'Ticket Created', text: success, confirmButtonColor: '#4b41e1' });
            if (error) Swal.fire({ icon: 'error', title: 'Oops...', text: error, confirmButtonColor: '#ba1a1a' });
        });
    </script>
    <%- include("partials/support_bubble") %>
</body>
</html>
