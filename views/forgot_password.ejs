<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Forgot Password | NI DRIP CENTRAL</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
          tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                colors: {
                  "tertiary-container": "#261906",
                  "on-secondary-container": "#fffbff",
                  "secondary": "#4b41e1",
                  "on-primary-fixed": "#141b2b",
                  "on-error-container": "#93000a",
                  "on-secondary": "#ffffff",
                  "surface-variant": "#e1e3e4",
                  "surface-tint": "#575e70",
                  "outline": "#76777d",
                  "on-surface": "#191c1d",
                  "error": "#ba1a1a",
                  "on-primary-fixed-variant": "#404758",
                  "surface-dim": "#d9dadb",
                  "surface": "#f8f9fa",
                  "surface-container-highest": "#e1e3e4",
                  "outline-variant": "#c6c6cd",
                  "inverse-primary": "#c0c6db",
                  "inverse-on-surface": "#f0f1f2",
                  "on-background": "#191c1d",
                  "background": "#f8f9fa",
                  "surface-bright": "#f8f9fa",
                  "primary-container": "#141b2b",
                  "inverse-surface": "#2e3132",
                  "on-primary": "#ffffff",
                  "tertiary": "#000000",
                  "error-container": "#ffdad6",
                  "tertiary-fixed-dim": "#dcc2a4",
                  "secondary-container": "#645efb",
                  "on-surface-variant": "#45464c",
                  "on-error": "#ffffff",
                  "on-secondary-fixed": "#0f0069",
                  "tertiary-fixed": "#f9debf",
                  "on-tertiary-fixed": "#261906",
                  "surface-container": "#edeeef",
                  "surface-container-low": "#f3f4f5",
                  "on-tertiary-fixed-variant": "#55442d",
                  "primary-fixed-dim": "#c0c6db",
                  "primary": "#000000",
                  "on-primary-container": "#7d8497",
                  "secondary-fixed": "#e2dfff",
                  "on-tertiary": "#ffffff",
                  "on-tertiary-container": "#968065",
                  "on-secondary-fixed-variant": "#3323cc",
                  "secondary-fixed-dim": "#c3c0ff",
                  "primary-fixed": "#dce2f7",
                  "surface-container-high": "#e7e8e9",
                  "surface-container-lowest": "#ffffff"
                },
                fontFamily: {
                  "headline": ["Plus Jakarta Sans"],
                  "body": ["Inter"],
                  "label": ["Inter"]
                },
                borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
              },
            },
          }
        </script>
    <style>
            .material-symbols-outlined {
                font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
            }
            body {
                background-color: #f8f9fa;
                color: #191c1d;
            }
        </style>
    <style>
        body {
          min-height: max(884px, 100dvh);
        }
      </style>
</head>
<body class="font-body antialiased">
    <header class="fixed top-0 w-full z-50 bg-[#F8F9FA]/85 backdrop-blur-xl shadow-[0_12px_40px_rgba(25,28,29,0.04)]">
        <div class="flex items-center justify-between px-6 h-16 w-full max-w-screen-xl mx-auto">
            <div class="flex items-center gap-4">
                <button onclick="history.back()" class="flex items-center justify-center p-2 rounded-full active:scale-95 duration-200 hover:opacity-80 transition-opacity text-[#000000]">
                    <span class="material-symbols-outlined" data-icon="arrow_back">arrow_back</span>
                </button>
                <h1 class="font-headline font-bold tracking-tight text-[#000000] text-sm">NI DRIP CENTRAL</h1>
            </div>
            <div class="w-10 h-10"></div>
        </div>
    </header>
    <main class="min-h-screen pt-32 pb-16 px-8 max-w-md mx-auto flex flex-col justify-start">
        <section class="mb-12">
            <h2 class="font-headline text-[3.5rem] leading-[1.1] font-extrabold text-[#111827] -tracking-[0.04em] mb-4">
                Forgot <br/>Password
            </h2>
            <p class="font-body text-[#45464c] text-lg leading-relaxed max-w-[280px]">
                Enter the email associated with your account and we’ll send an instruction to reset your password.
            </p>
        </section>
        <form action="/forgot-password" method="POST" class="space-y-10">
            <div class="space-y-3">
                <label class="font-headline font-bold text-xs uppercase tracking-[0.1em] text-[#000000] ml-1" for="email">
                    Email Address
                </label>
                <div class="relative group">
                    <input name="user_email" class="w-full bg-[#f3f4f5] border-0 rounded-xl py-5 px-6 font-body text-on-surface focus:ring-0 focus:bg-white focus:outline-none transition-all duration-300 placeholder:text-outline-variant" id="email" placeholder="curator@dripped.com" type="email" required/>
                    <div class="absolute inset-0 border border-secondary opacity-0 group-focus-within:opacity-10 pointer-events-none rounded-xl transition-opacity"></div>
                </div>
            </div>
            <div class="pt-4">
                <button type="submit" class="w-full bg-[#000000] text-white font-headline font-bold py-5 rounded-xl active:scale-[0.98] transition-all duration-200 shadow-lg shadow-primary/5 hover:bg-primary-container">
                    Send Reset Link
                </button>
            </div>
        </form>
        <div class="mt-auto pt-20 flex flex-col items-center">
            <div class="w-12 h-1 bg-surface-container-high rounded-full mb-8"></div>
            <p class="font-body text-xs text-outline-variant tracking-widest uppercase">NI Drip Central Curator Program</p>
        </div>
    </main>
</body>
</html>

