<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NI DRIP - Forgot Password</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body>
  <div class="mobile-frame">
    <div class="auth-bg">
      <!-- Header -->
      <button class="login-back-btn" onclick="history.back()"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8L10 4" stroke="#1B1B1B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
      
      <h1 class="login-header-title">Forgot Password</h1>

      <div class="forgot-password-container">
        <p style="text-align: left; color: #4B4B4B; font-size: 14px; font-family: 'Poppins'; margin-bottom: 0;">
          Don't worry! It happens. Please enter the email associated with your account.
        </p>

        <form action="/forgot-password" method="POST" style="width: 100%; display: flex; flex-direction: column; gap: 40px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="login-form-group">
            <div class="login-input-wrapper">
              <label class="login-label">Email</label>
              <input type="email" name="user_email" class="login-input" placeholder="Text your email" required>
            </div>
          </div>

          <button type="submit" class="auth-btn-primary" style="width: 100%;">Confirm</button>
        </form>
      </div>

      <!-- Keyboard Spacer -->
      <div class="flex-grow"></div>
      
      <!-- Home Indicator -->
      <div style="width: 134px; height: 5px; background: #000000; border-radius: 100px; margin: 0 auto 10px; opacity: 0.1;"></div>
    </div>
  </div>
</body>
</html>
